---
layout: base
title: Bookshelf Timeline
description: The freethought canon arranged chronologically — from Hume to Russell.
permalink: /bookshelf/timeline/
eleventyExcludeFromCollections: true
---

{% set works = library.works | sort(false, false, 'year') %}

<div class="container" style="padding-top: var(--space-10); padding-bottom: var(--space-20);">

  <header style="padding-bottom: var(--space-6); border-bottom: 3px solid var(--color-ink); margin-bottom: var(--space-10); text-align: center;">
    <h1 style="font-family: var(--font-masthead); font-size: clamp(1.8rem, 5vw, 3.815rem); margin-bottom: var(--space-4);">Bookshelf Timeline</h1>
    <p style="color: var(--color-ink-muted); font-size: var(--text-md); font-style: italic; max-width: 40ch; margin-inline: auto;">
      The freethought canon, in the order it was written.
    </p>
    <p style="margin-top:var(--space-4);"><a href="/library/" style="font-family:var(--font-ui);font-size:var(--text-xs);color:var(--color-link);">&larr; Library</a></p>
  </header>

  <div class="tl" data-pagefind-ignore>
    <div class="tl__line" aria-hidden="true"></div>

    {% set currentEra = '' %}
    {% for work in works %}
      {% if not work.isParent %}

      {% if work.era != currentEra %}
        {% set currentEra = work.era %}
        <div class="tl__era">
          <span class="tl__era-label">{{ work.era }}</span>
        </div>
      {% endif %}

      <div class="tl__event {% if loop.index0 % 2 == 0 %}tl__event--left{% else %}tl__event--right{% endif %}">
        <div class="tl__connector" aria-hidden="true"></div>
        <div class="tl__dot" aria-hidden="true"></div>
        <div class="tl__card">
          <div class="tl__year">{{ work.year }}</div>
          <h2 class="tl__title"><a href="/library/{{ work.slug }}/">{{ work.title }}</a></h2>
          <p style="font-family:var(--font-ui);font-size:var(--text-xs);color:var(--color-ink-muted);margin:0 0 var(--space-2);">
            {{ work.author }}
            <span style="display:inline-block;margin-left:var(--space-2);padding:1px 6px;font-size:10px;border:1px solid var(--color-rule);text-transform:uppercase;letter-spacing:0.06em;">{{ work.type }}</span>
            {% if work.difficulty %}<span style="display:inline-block;margin-left:var(--space-1);padding:1px 6px;font-size:10px;border:1px solid var(--color-rule);text-transform:uppercase;letter-spacing:0.06em;">{{ work.difficulty }}</span>{% endif %}
          </p>
          <p class="tl__desc">{{ work.description }}</p>
        </div>
      </div>

      {% endif %}
    {% endfor %}
  </div>
</div>

{% include "partials/timeline-styles.njk" %}

<script>
(function () {
  if ('IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) { entry.target.classList.add('is-visible'); observer.unobserve(entry.target); }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.tl__event').forEach(function (el) { observer.observe(el); });
  } else {
    document.querySelectorAll('.tl__event').forEach(function (el) { el.classList.add('is-visible'); });
  }
})();
</script>
