---
layout: layouts/base.njk
title: Contributors
description: The writers and editors of The Freethinking Times.
permalink: /contributors/
---

<div class="container" style="padding-top: var(--space-10); padding-bottom: var(--space-20);">

  <header class="section-header" style="margin-bottom: var(--space-8);">
    <h1 style="font-family: var(--font-masthead); font-size: var(--text-3xl); margin: 0 0 var(--space-3);">Contributors</h1>
    <p style="color: var(--color-ink-muted); font-size: var(--text-md); max-width: 60ch; font-style: italic; margin: 0;">
      The writers, editors, and reporters of {{ site.title }}.
    </p>
  </header>

  <div class="contributors-grid">
    {% for slug, authorData in authors %}
    {% set authorArticles = collections.allContent | where("author", slug) %}
    {% set lastArticle = authorArticles | first %}
    {% set firstArticle = authorArticles | last %}
    {% set totalWords = 0 %}
    {% set totalReadMins = 0 %}
    {% for item in authorArticles %}
      {% if item.templateContent %}
        {% set totalWords = totalWords + (item.templateContent | wordCountRaw) %}
        {% set totalReadMins = totalReadMins + (item.templateContent | readingMins) %}
      {% endif %}
    {% endfor %}
    <article class="author-card">
      <div class="author-card__avatar">
        <div class="author-card__initials" aria-hidden="true">{{ authorData.name | initials }}</div>
        {% if authorData.photo %}
          {% set photoSrc = authorData.photo | replace("src", "") %}
          <img src="{{ photoSrc }}" alt="{{ authorData.name }}"
               class="author-card__photo" width="88" height="88" loading="lazy" decoding="async"
               onerror="this.style.opacity=0">
        {% endif %}
      </div>

      <div class="author-card__body">
        {% if authorData.role %}
        <p class="author-card__role">{{ authorData.role }}</p>
        {% endif %}
        <h2 class="author-card__name"><a href="/author/{{ slug }}/"
          {% if authorData.bio %}data-tippy-content="{{ authorData.bio }}" data-tippy-theme="author-bio"{% endif %}>{{ authorData.name }}</a></h2>
        {% if authorData.bio %}
        <p class="author-card__bio">{{ authorData.bio }}</p>
        {% endif %}

        {% set social = authorData.social %}
        {% include "partials/social-icons.njk" %}

        {% if authorArticles.length %}
        <div class="author-card__stats">
          <span class="author-card__stat"><strong>{{ authorArticles.length }}</strong> {{ "article" if authorArticles.length == 1 else "articles" }}</span>
          {% if totalWords > 0 %}<span class="author-card__stat"><strong>{{ (totalWords / 1000) | round(1) }}k</strong> words</span>{% endif %}
          {% if totalReadMins > 0 %}<span class="author-card__stat"><strong>~{{ totalReadMins }}m</strong> reading</span>{% endif %}
          {% if lastArticle and lastArticle.date %}
          <span class="author-card__stat">Last published <strong>{{ lastArticle.date | readableDate }}</strong></span>
          {% endif %}
        </div>
        {% endif %}

        <div class="author-card__footer">
          <a class="author-card__link" href="/author/{{ slug }}/">View articles &rarr;</a>
          {% set tipAuthor = authorData %}
          {% set tipHidePublication = true %}
          {% include "partials/tip-buttons.njk" %}
        </div>
      </div>
    </article>
    {% endfor %}
  </div>

</div>
