          id="ty-subscribe-email"
          type="email"
          name="email"
          placeholder="you@example.com"
          autocomplete="email"
          required>
        <button class="ty-form__btn subscribe-form__btn" type="submit">Subscribe</button>
      </form>
      <div class="subscribe-status ty-card__status" role="alert" aria-live="polite"></div>
    </aside>

