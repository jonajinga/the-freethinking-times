---
layout: base
title: Notes & Highlights
description: All your highlights, annotations, and bookmarks across the site. Stored locally in your browser — no account required.
permalink: /notes/
---

<div class="container" style="padding-top: var(--space-10); padding-bottom: var(--space-20);">

  <header style="padding-bottom: var(--space-8); border-bottom: 3px solid var(--color-ink); margin-bottom: var(--space-8);">
    <h1 style="font-family: var(--font-masthead); font-size: var(--text-3xl); margin-bottom: var(--space-2);">Notes & Highlights</h1>
    <p style="color: var(--color-ink-muted); font-size: var(--text-md); font-style: italic;">
      Your highlights, notes, and bookmarks across the site. Stored in your browser — nothing is sent anywhere.
    </p>
  </header>

  <div id="notes-page-root">
    <p style="color: var(--color-ink-faint); font-style: italic;">Loading…</p>
  </div>

</div>

<style>
@media print {
  button, input, select,
  .article-action-btn,
  .library-annotation-item__actions,
  .library-bookmark-item__delete,
  .search-filter-btn,
  .reading-list-clear,
  [style*="gap"] > button,
  [style*="gap"] > a { display: none !important; }

  [data-page-section] a[style] { display: inline !important; }
}
</style>

{% block scripts %}
<script src="/assets/js/notes-page.js" defer></script>
{% endblock %}
