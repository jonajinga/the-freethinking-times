---
layout: base
title: Archives
description: The complete archive of The Freethinking Times — every article, filterable by section, author, and date.
permalink: /archives/
---

<div class="container" style="padding-top: var(--space-10); padding-bottom: var(--space-20);">

  <header class="archive-header">
    <h1 style="font-family: var(--font-masthead); font-size: clamp(1.8rem, 5vw, 3.815rem); margin-bottom: var(--space-4);">Archives</h1>
    <p style="font-size: var(--text-lg); color: var(--color-ink-muted); font-style: italic;">
      Every piece published in The Freethinking Times, in reverse chronological order.
    </p>
  </header>

  {# ── Filter toolbar ─────────────────────────────────────── #}
  <div class="archive-toolbar" role="search" aria-label="Filter articles">
    <div class="archive-toolbar__controls">

      <label class="visually-hidden" for="archive-search">Search articles</label>
      <input
        id="archive-search"
        class="archive-search"
        type="search"
        placeholder="Search titles and descriptions…"
        autocomplete="off"
        aria-label="Search articles"
      >

      <label class="visually-hidden" for="archive-section">Filter by section</label>
      <select id="archive-section" class="archive-select" aria-label="Filter by section">
        <option value="">All Sections</option>
      </select>

      <label class="visually-hidden" for="archive-author">Filter by author</label>
      <select id="archive-author" class="archive-select" aria-label="Filter by author">
        <option value="">All Authors</option>
      </select>

      <label class="visually-hidden" for="archive-year">Filter by year</label>
      <select id="archive-year" class="archive-select" aria-label="Filter by year">
        <option value="">All Years</option>
      </select>

      <label class="visually-hidden" for="archive-month">Filter by month</label>
      <select id="archive-month" class="archive-select" aria-label="Filter by month">
        <option value="">All Months</option>
        <option value="1">January</option>
        <option value="2">February</option>
        <option value="3">March</option>
        <option value="4">April</option>
        <option value="5">May</option>
        <option value="6">June</option>
        <option value="7">July</option>
        <option value="8">August</option>
        <option value="9">September</option>
        <option value="10">October</option>
        <option value="11">November</option>
        <option value="12">December</option>
      </select>

      <button id="archive-clear" class="archive-clear" type="button" hidden>Clear filters</button>

    </div>
    <p class="archive-meta" id="archive-count" aria-live="polite" aria-atomic="true"></p>
  </div>

  {# ── Article groups ──────────────────────────────────────── #}
  {% set dateGroups = collections.allContent | groupByDate %}

  <div id="archive-list">

    {% for group in dateGroups %}
    <section
      class="archive-group"
      id="group-{{ group.date }}"
      data-group-date="{{ group.date }}"
    >

      <h2 class="archive-group__heading">
        <a href="#group-{{ group.date }}">{{ group.articles[0].date | readableDate | upper }}</a>
      </h2>

      <ul class="article-list" role="list">
        {% for item in group.articles %}
        {# Compute values for data attributes #}
        {% set itemDate = item.date | htmlDateString %}
        {% set itemYear = item.date | readableDate %}
        {% set authorSlug = item.data.author %}
        {% set authorName = authors[authorSlug].name if (authorSlug and authors[authorSlug]) else "The Freethinking Times" %}
        {% set itemSection = item.data.section if item.data.section else "" %}
        {% set itemTitle = item.data.title if item.data.title else "" %}
        {% set itemDesc = item.data.description if item.data.description else "" %}
        {# Extract year and month from date string YYYY-MM-DD #}
        {% set dateParts = itemDate.split("-") %}

        <li
          class="article-list__item archive-entry"
          data-title="{{ itemTitle | lower }}"
          data-desc="{{ itemDesc | lower }}"
          data-section="{{ itemSection }}"
          data-author="{{ authorSlug }}"
          data-author-name="{{ authorName }}"
          data-year="{{ dateParts[0] }}"
          data-month="{{ dateParts[1] | int }}"
        >

          {# Top row: date + section badge #}
          <div class="archive-entry__top">
            <time class="archive-entry__date" datetime="{{ itemDate }}">
              {{ item.date | readableDate | upper }}
            </time>
            {% if itemSection %}
            <a
              href="/{{ itemSection | slugify }}/"
              class="section-badge section-badge--{{ itemSection | slugify }}"
            >{{ itemSection }}</a>
            {% endif %}
          </div>

          {# Title #}
          <h3 class="archive-entry__title">
            <a href="{{ item.url }}">{{ itemTitle }}</a>
          </h3>

          {# Description #}
          {% if itemDesc %}
          <p class="archive-entry__desc">{{ itemDesc }}</p>
          {% endif %}

          {# Meta row: author · reading time · word count #}
          <div class="article-list__meta">
            <span>BY
              <a href="/author/{{ authorSlug }}/" class="archive-entry__author">{{ authorName | upper }}</a>
            </span>
            <span aria-hidden="true">·</span>
            <span>{{ item.templateContent | readingTime }}</span>
            <span aria-hidden="true">·</span>
            <span>{{ item.templateContent | wordCount }}</span>
          </div>

        </li>
        {% endfor %}
      </ul>

    </section>
    {% endfor %}

    {# Empty state #}
    <div class="archive-empty" id="archive-empty" hidden>
      <p>No articles match your filters. <button type="button" onclick="archiveClearAll()">Clear all filters</button> to start over.</p>
    </div>

  </div>

</div>

<script>
(function () {
  const searchEl   = document.getElementById('archive-search');
  const sectionEl  = document.getElementById('archive-section');
  const authorEl   = document.getElementById('archive-author');
  const yearEl     = document.getElementById('archive-year');
  const monthEl    = document.getElementById('archive-month');
  const clearBtn   = document.getElementById('archive-clear');
  const countEl    = document.getElementById('archive-count');
  const emptyEl    = document.getElementById('archive-empty');
  const entries    = Array.from(document.querySelectorAll('.archive-entry'));
  const groups     = Array.from(document.querySelectorAll('.archive-group'));
  const total      = entries.length;

  // ── Populate dropdowns from data ────────────────────────────
  const unique = (arr) => [...new Set(arr)].filter(Boolean).sort((a, b) => a.localeCompare(b));

  const sections = unique(entries.map(e => e.dataset.section));
  sections.forEach(s => {
    const opt = document.createElement('option');
    opt.value = s;
    opt.textContent = s;
    sectionEl.appendChild(opt);
  });

  // Authors: collect slug → display name pairs
  const authorMap = {};
  entries.forEach(e => {
    if (e.dataset.author) authorMap[e.dataset.author] = e.dataset.authorName;
  });
  Object.keys(authorMap).sort((a, b) => authorMap[a].localeCompare(authorMap[b])).forEach(slug => {
    const opt = document.createElement('option');
    opt.value = slug;
    opt.textContent = authorMap[slug];
    authorEl.appendChild(opt);
  });

  const years = unique(entries.map(e => e.dataset.year)).sort((a, b) => b - a);
  years.forEach(y => {
    const opt = document.createElement('option');
    opt.value = y;
    opt.textContent = y;
    yearEl.appendChild(opt);
  });

  // ── Update count display ─────────────────────────────────────
  function updateCount(visible) {
    if (visible === total) {
      countEl.textContent = total + ' article' + (total !== 1 ? 's' : '');
    } else {
      countEl.textContent = 'Showing ' + visible + ' of ' + total + ' article' + (total !== 1 ? 's' : '');
    }
  }

  // ── Core filter function ─────────────────────────────────────
  function applyFilters() {
    const q       = searchEl.value.trim().toLowerCase();
    const section = sectionEl.value;
    const author  = authorEl.value;
    const year    = yearEl.value;
    const month   = monthEl.value;

    const anyActive = q || section || author || year || month;
    clearBtn.hidden = !anyActive;

    let visible = 0;

    entries.forEach(entry => {
      let show = true;

      if (q && !entry.dataset.title.includes(q) && !entry.dataset.desc.includes(q)) show = false;
      if (section && entry.dataset.section !== section) show = false;
      if (author  && entry.dataset.author  !== author)  show = false;
      if (year    && entry.dataset.year    !== year)     show = false;
      if (month   && String(parseInt(entry.dataset.month, 10)) !== month) show = false;

      entry.hidden = !show;
      if (show) visible++;
    });

    // Hide groups where all children are hidden
    groups.forEach(group => {
      const anyVisible = group.querySelectorAll('.archive-entry:not([hidden])').length > 0;
      group.hidden = !anyVisible;
    });

    updateCount(visible);
    emptyEl.hidden = visible > 0;
  }

  // ── Event listeners ──────────────────────────────────────────
  let searchTimer;
  searchEl.addEventListener('input', () => {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(applyFilters, 200);
  });

  [sectionEl, authorEl, yearEl, monthEl].forEach(el => {
    el.addEventListener('change', applyFilters);
  });

  clearBtn.addEventListener('click', archiveClearAll);

  // ── Global clear (also called from empty state button) ───────
  window.archiveClearAll = function () {
    searchEl.value = '';
    sectionEl.value = '';
    authorEl.value = '';
    yearEl.value = '';
    monthEl.value = '';
    applyFilters();
  };

  // ── Init ─────────────────────────────────────────────────────
  updateCount(total);
})();
</script>
