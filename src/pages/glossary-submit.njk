---
layout: base
title: "Suggest a Glossary Term"
description: Know a term that belongs in the freethought glossary? Suggest it.
permalink: /glossary/submit/
---

<div class="container" style="padding-top: var(--space-10); padding-bottom: var(--space-20);">
  <div class="container--prose">

    <header style="margin-bottom: var(--space-10); padding-bottom: var(--space-6); border-bottom: 3px solid var(--color-ink);">
      <nav style="font-family:var(--font-ui);font-size:var(--text-xs);color:var(--color-ink-faint);margin-bottom:var(--space-4);">
        <a href="/glossary/" style="color:var(--color-link);">Glossary</a> &rarr; Suggest a Term
      </nav>
      <h1 style="font-family: var(--font-masthead); font-size: clamp(1.8rem, 5vw, 3.815rem); margin-bottom: var(--space-4);">Suggest a Glossary Term</h1>
      <p style="font-family: var(--font-body); font-size: var(--text-lg); color: var(--color-ink-muted); line-height: var(--leading-loose); max-width: 60ch;">
        The glossary covers key terms in freethought, philosophy, and secular discourse. Suggest a term we should define.
      </p>
    </header>

    <div class="article-body">
      <form action="https://api.web3forms.com/submit" method="POST" class="w3f" style="margin: var(--space-6) 0;">
        <input type="hidden" name="access_key" value="{{ site.forms.accessKey }}">
        <input type="hidden" name="subject" value="Glossary term suggestion — {{ site.title }}">
        <input type="hidden" name="redirect" value="{{ site.url }}/thank-you/">
        <input type="hidden" name="from_name" value="{{ site.title }} Glossary Form">
        <input type="checkbox" name="botcheck" class="visually-hidden" style="display:none" tabindex="-1" autocomplete="off">

        <div class="w3f__group">
          <label class="w3f__label" for="gl-term">Term <span class="w3f__required">*</span></label>
          <input class="w3f__input" type="text" name="term" id="gl-term" required aria-required="true" placeholder="e.g. Deism">
        </div>

        <div class="w3f__group">
          <label class="w3f__label" for="gl-def">Suggested definition <span class="w3f__optional">(optional)</span></label>
          <span class="w3f__hint" id="gl-def-hint">A brief definition in your own words. We'll write the full entry, but this helps us understand what you have in mind.</span>
          <textarea class="w3f__textarea" name="definition" id="gl-def" rows="3" aria-describedby="gl-def-hint" maxlength="1000"></textarea>
        </div>

        <div class="w3f__group">
          <label class="w3f__label" for="gl-why">Why should this term be included? <span class="w3f__optional">(optional)</span></label>
          <textarea class="w3f__textarea" name="reason" id="gl-why" rows="3" maxlength="1000" placeholder="Is it commonly misunderstood? Central to a specific debate?"></textarea>
        </div>

        <div class="w3f__row">
          <div class="w3f__group">
            <label class="w3f__label" for="gl-name">Your name <span class="w3f__optional">(optional)</span></label>
            <input class="w3f__input" type="text" name="name" id="gl-name" autocomplete="name">
          </div>
          <div class="w3f__group">
            <label class="w3f__label" for="gl-email">Email <span class="w3f__optional">(optional)</span></label>
            <input class="w3f__input" type="email" name="email" id="gl-email" autocomplete="email">
          </div>
        </div>

        <div class="h-captcha" data-captcha="true"></div>
        <button type="submit" class="w3f__submit">Submit Suggestion</button>
      </form>
    </div>
  </div>
</div>
