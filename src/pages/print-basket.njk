---
layout: base
title: Print basket
description: Print your selected articles as a single PDF. Articles are loaded from the basket you built while reading; rearrange or remove items, then print to PDF in your browser.
permalink: /print-basket/
---

<div class="container" style="padding-top: var(--space-10); padding-bottom: var(--space-20);">
  <div class="container--prose">

    <header style="margin-bottom: var(--space-6); padding-bottom: var(--space-6); border-bottom: 3px solid var(--color-ink);">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <ol class="breadcrumbs__list">
          <li class="breadcrumbs__item"><a class="breadcrumbs__link" href="/">Home</a></li>
          <li class="breadcrumbs__item"><a class="breadcrumbs__link" href="/reader/">Reader</a></li>
          <li class="breadcrumbs__item breadcrumbs__item--current" aria-current="page">Print basket</li>
        </ol>
      </nav>
      <h1 style="font-family: var(--font-masthead); font-size: clamp(1.8rem, 5vw, 3.815rem); margin-bottom: var(--space-4);">Print basket</h1>
      <p style="font-family: var(--font-body); font-size: var(--text-lg); color: var(--color-ink-muted); line-height: var(--leading-loose); max-width: 60ch;">
        The articles you've added with <strong>Add to PDF</strong>. Hit print — your browser will combine them into a single PDF you can save or share.
      </p>
    </header>

    <div id="print-basket-empty" style="font-family: var(--font-body); padding: var(--space-8); border: 1px dashed var(--color-rule); text-align: center; color: var(--color-ink-muted);" hidden>
      <p style="margin-bottom: var(--space-3);">Your print basket is empty.</p>
      <p>Open any article and click <strong>Add to PDF</strong> in the action row, then come back here to print them all in one go.</p>
    </div>

    <div id="print-basket-controls" style="display: flex; gap: var(--space-3); flex-wrap: wrap; margin-bottom: var(--space-6); font-family: var(--font-ui); font-size: var(--text-sm); align-items: center;" hidden>
      <span><strong data-pb-count>0</strong> articles &middot; estimated <strong data-pb-pages>0</strong> pages</span>
      <button type="button" id="pb-print" style="margin-left: auto; background: var(--color-ink); color: var(--color-bg); border: 0; padding: var(--space-2) var(--space-4); cursor: pointer; font-family: inherit; font-size: inherit; font-weight: 700;"
        onclick="window.print();" data-umami-event="pdf-basket-print">Print &rarr; Save as PDF</button>
      <button type="button" id="pb-clear" style="background: none; border: 1px solid var(--color-rule); padding: var(--space-2) var(--space-3); cursor: pointer; font-family: inherit; font-size: inherit; color: var(--color-ink-muted);"
        onclick="if(confirm('Empty your print basket?')){localStorage.removeItem('tft-pdf-basket');location.reload();}">Empty basket</button>
    </div>

    <ul id="print-basket-list" class="pb-list" style="list-style: none; padding: 0; margin: 0; border-top: 1px solid var(--color-rule);"></ul>

  </div>
</div>

{# The actual rendering surface — fetches each article body and stacks them. #}
<div id="print-basket-render" class="pb-render" hidden></div>

<style>
.pb-list li {
  border-bottom: 1px solid var(--color-rule);
  padding: var(--space-4) 0;
  display: grid;
  grid-template-columns: 1fr auto auto;
  gap: var(--space-2) var(--space-4);
  align-items: baseline;
}
.pb-list a {
  font-family: var(--font-headline);
  font-size: var(--text-lg);
  font-weight: 700;
  color: var(--color-ink);
  text-decoration: none;
}
.pb-list a:hover { color: var(--color-accent); }
.pb-meta {
  font-family: var(--font-ui);
  font-size: var(--text-xs);
  color: var(--color-ink-muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}
.pb-list button {
  background: none;
  border: 0;
  color: var(--color-ink-muted);
  cursor: pointer;
  font-family: var(--font-ui);
  font-size: var(--text-xs);
  text-decoration: underline;
  padding: 0;
}
.pb-list button:hover { color: var(--color-accent); }

.pb-render { display: none; }
.pb-render__article {
  page-break-after: always;
  padding: var(--space-8) 0;
}
.pb-render__article:last-child { page-break-after: auto; }
.pb-render__article h1 {
  font-family: var(--font-masthead);
  font-size: 2.2rem;
  margin-bottom: var(--space-2);
  line-height: 1.15;
}
.pb-render__article .pb-render__byline {
  font-family: var(--font-ui);
  font-size: var(--text-sm);
  color: var(--color-ink-muted);
  margin-bottom: var(--space-4);
  border-bottom: 1px solid var(--color-rule);
  padding-bottom: var(--space-3);
}

@media print {
  body > *:not(.pb-render):not(.print-header) { display: none !important; }
  .pb-render { display: block !important; }
  .pb-render__article { padding: 0; margin-bottom: 2rem; }
}
</style>

<script>
(function () {
  'use strict';
  function load() { try { return JSON.parse(localStorage.getItem('tft-pdf-basket')) || []; } catch (e) { return []; } }
  function save(arr) { try { localStorage.setItem('tft-pdf-basket', JSON.stringify(arr)); } catch (e) {} }

  function fmtDate(s) {
    if (!s) return '';
    var d = new Date(s);
    if (isNaN(d)) return '';
    return d.toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' });
  }

  function init() {
    var listEl = document.getElementById('print-basket-list');
    var empty = document.getElementById('print-basket-empty');
    var controls = document.getElementById('print-basket-controls');
    var render = document.getElementById('print-basket-render');
    if (!listEl) return;

    var basket = load();
    if (!basket.length) {
      empty.hidden = false;
      return;
    }
    controls.hidden = false;
    controls.querySelector('[data-pb-count]').textContent = basket.length;

    listEl.innerHTML = basket.map(function (item, i) {
      var meta = [item.section, fmtDate(item.date), item.author].filter(Boolean).join(' &middot; ');
      return '<li data-pb-index="' + i + '">' +
        '<div><a href="' + item.url + '">' + (item.title || item.url) + '</a>' + (meta ? '<div class="pb-meta" style="margin-top: 4px;">' + meta + '</div>' : '') + '</div>' +
        '<button type="button" data-pb-up>&uarr;</button>' +
        '<button type="button" data-pb-remove>Remove</button>' +
        '</li>';
    }).join('');

    listEl.addEventListener('click', function (ev) {
      var li = ev.target.closest('[data-pb-index]');
      if (!li) return;
      var i = Number(li.getAttribute('data-pb-index'));
      var arr = load();
      if (ev.target.matches('[data-pb-remove]')) {
        arr.splice(i, 1);
      } else if (ev.target.matches('[data-pb-up]') && i > 0) {
        var t = arr[i]; arr[i] = arr[i - 1]; arr[i - 1] = t;
      } else {
        return;
      }
      save(arr);
      location.reload();
    });

    // Pre-fetch each article body so the print run renders all content at
    // once. We use the page itself, parse out .article-body, and stack the
    // pieces in the hidden render container.
    Promise.all(basket.map(function (item) {
      return fetch(item.url, { credentials: 'same-origin' })
        .then(function (r) { return r.ok ? r.text() : ''; })
        .then(function (html) {
          if (!html) return null;
          var doc = new DOMParser().parseFromString(html, 'text/html');
          var body = doc.querySelector('.article-body, .library-body, [data-pagefind-body]');
          if (!body) return null;
          // Strip interactive chrome we don't want in print
          body.querySelectorAll('.article-action-btn, .share-panel, .share-wrap, [data-tts-skip], .article-comments, .responses-section').forEach(function (n) { n.remove(); });
          return { item: item, html: body.innerHTML };
        })
        .catch(function () { return null; });
    })).then(function (parts) {
      var totalChars = 0;
      var pieces = parts.filter(Boolean).map(function (p) {
        totalChars += p.html.replace(/<[^>]+>/g, '').length;
        var meta = [p.item.author, p.item.section, fmtDate(p.item.date)].filter(Boolean).join(' &middot; ');
        return '<article class="pb-render__article">' +
          '<h1>' + (p.item.title || p.item.url) + '</h1>' +
          (meta ? '<div class="pb-render__byline">' + meta + '</div>' : '') +
          p.html +
        '</article>';
      });
      render.innerHTML = pieces.join('');
      // Rough estimate: ~3000 chars / printed page at our type sizes
      var est = Math.max(1, Math.ceil(totalChars / 3000));
      var pagesEl = controls.querySelector('[data-pb-pages]');
      if (pagesEl) pagesEl.textContent = est;
    });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>
