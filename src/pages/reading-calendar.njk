---
layout: base
title: Reading calendar
description: A personal calendar of the articles you've read, drawn from this device's local reading history.
permalink: /reading-calendar/
---
<main class="container reading-cal" data-pagefind-ignore>

  <header class="reading-cal__header">
    <p class="reading-cal__kicker">Reader tools</p>
    <h1 class="reading-cal__title">Reading calendar</h1>
    <p class="reading-cal__lede">
      The articles you&rsquo;ve read, by date. Switch between day,
      week, month, and year views &mdash; click any day in the grid
      to drill in. Drawn entirely from this device&rsquo;s local
      history; no account, no server.
    </p>
  </header>

  <div class="reading-cal__summary" id="reading-cal-summary"></div>

  <div id="reading-cal-mount" class="cal-mount" aria-live="polite">
    <p class="cal-loading">Loading your reading history&hellip;</p>
  </div>

  {% include "partials/calendar-data.njk" %}

  <noscript>
    <p class="cal-noscript">
      The reading calendar reads your local history with JavaScript.
      Without JS the calendar can&rsquo;t render.
    </p>
  </noscript>

</main>

<script src="/assets/js/calendar-shared.js?v={{ buildTime }}" defer></script>
<script>
(function () {
  var PREFIX = (window.__PREFIX || 'tft');
  var KEY_MANUAL = PREFIX + '-read-manual';
  var KEY_PCT    = PREFIX + '-read-pct';

  function load(key) {
    try { return JSON.parse(localStorage.getItem(key)) || {}; } catch (e) { return {}; }
  }

  function buildHistory() {
    // tft-read-manual stores explicit "mark as read" events with
    // markedAt timestamps — these are the canonical reading dates.
    // tft-read-pct entries are auto-tracked scroll progress per URL.
    // Only entries on article pages (.article-body, .library-body) get
    // written there per reading-progress.js, so we know it's articles
    // and not other surfaces. Pct entries lack a date stamp, so we
    // file completed articles (>=95%) under "today" only as a last
    // resort and tag them as approximate so the user knows.
    var manual = load(KEY_MANUAL);
    var pct    = load(KEY_PCT);
    var todayISO = new Date().toISOString().slice(0, 10);
    var hist = Object.create(null);
    Object.keys(manual).forEach(function (url) {
      var rec = manual[url];
      if (!rec) return;
      hist[url] = (rec.markedAt || todayISO + 'T00:00:00').slice(0, 10);
    });
    Object.keys(pct).forEach(function (url) {
      if (hist[url]) return;
      if (pct[url] >= 95) hist[url] = todayISO;
    });
    return hist;
  }

  function buildSummary(hist) {
    var summary = document.getElementById('reading-cal-summary');
    if (!summary) return;
    var urls = Object.keys(hist);
    if (!urls.length) { summary.innerHTML = ''; return; }
    var dateSet = new Set(urls.map(function (u) { return hist[u]; }));
    var monthSet = new Set([...dateSet].map(function (d) { return d.slice(0, 7); }));
    summary.innerHTML =
      '<div class="reading-cal__stat"><span class="reading-cal__stat-num">' + urls.length + '</span> articles read</div>'
    + '<div class="reading-cal__stat"><span class="reading-cal__stat-num">' + dateSet.size + '</span> reading days</div>'
    + '<div class="reading-cal__stat"><span class="reading-cal__stat-num">' + monthSet.size + '</span> months active</div>';
  }

  function init() {
    var root = document.getElementById('reading-cal-mount');
    if (!root || !window.TFTCalendar) return;
    var history = buildHistory();
    buildSummary(history);
    window.TFTCalendar.mount({ root: root, mode: 'reading', history: history });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  document.addEventListener('spa:contentswap', init);
})();
</script>
