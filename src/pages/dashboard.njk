---
layout: base
title: Editorial Dashboard
description: Content status overview for The Freethinking Times editorial team.
permalink: /dashboard/
eleventyExcludeFromCollections: true
---

{% set editorialSections = ["news", "opinion", "analysis", "arts-culture", "science-technology", "history", "letters", "reviews"] %}
{% set tbl = 'style="width:100%;font-size:var(--text-sm);border-collapse:collapse;margin:var(--space-6) 0;"' %}
{% set th = 'style="padding:var(--space-2);text-align:left;"' %}
{% set thr = 'style="padding:var(--space-2);text-align:right;"' %}
{% set td = 'style="padding:var(--space-2);"' %}
{% set tdr = 'style="padding:var(--space-2);text-align:right;"' %}
{% set rowb = 'style="border-bottom:1px solid var(--color-rule);"' %}
{% set headb = 'style="border-bottom:2px solid var(--color-ink);text-align:left;"' %}
{% set footb = 'style="border-top:2px solid var(--color-ink);font-weight:700;"' %}

<div class="container" style="padding-top: var(--space-10); padding-bottom: var(--space-20);">

  <header style="padding-bottom: var(--space-8); border-bottom: 3px solid var(--color-ink); margin-bottom: var(--space-8);">
    <h1 style="font-family: var(--font-masthead); font-size: var(--text-3xl); margin-bottom: var(--space-2);">Editorial Dashboard</h1>
    <p style="color: var(--color-ink-muted); font-size: var(--text-md);">
      Content overview across all sections.
    </p>
  </header>

  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:var(--space-6);margin-bottom:var(--space-10);">

    {# ── Articles by Section ── #}
    <div>
      <h2 style="font-family:var(--font-headline);font-size:var(--text-md);margin-bottom:var(--space-2);">Articles by Section</h2>
      <table {{ tbl | safe }}>
        <thead><tr {{ headb | safe }}><th {{ th | safe }}>Section</th><th {{ thr | safe }}>Count</th></tr></thead>
        <tbody>
          {% for key in editorialSections %}
          {% if collections[key] %}
          <tr {{ rowb | safe }}>
            <td {{ td | safe }}><a href="/{{ key }}/">{{ site.sections[key].label }}</a></td>
            <td {{ tdr | safe }}>{{ collections[key].length }}</td>
          </tr>
          {% endif %}
          {% endfor %}
          <tr {{ footb | safe }}><td {{ td | safe }}>Total</td><td {{ tdr | safe }}>{{ collections.allContent.length }}</td></tr>
        </tbody>
      </table>
    </div>

    {# ── Articles by Status ── #}
    <div>
      <h2 style="font-family:var(--font-headline);font-size:var(--text-md);margin-bottom:var(--space-2);">Articles by Status</h2>
      {% set draftCount = { n: 0 } %}
      {% set reviewCount = { n: 0 } %}
      {% set publishedCount = { n: 0 } %}
      {% for article in collections.allContent %}
        {% if article.data.status == "draft" or article.data.draft %}{% set draftCount = { n: draftCount.n + 1 } %}
        {% elif article.data.status == "review" %}{% set reviewCount = { n: reviewCount.n + 1 } %}
        {% else %}{% set publishedCount = { n: publishedCount.n + 1 } %}
        {% endif %}
      {% endfor %}
      <table {{ tbl | safe }}>
        <thead><tr {{ headb | safe }}><th {{ th | safe }}>Status</th><th {{ thr | safe }}>Count</th></tr></thead>
        <tbody>
          <tr {{ rowb | safe }}><td {{ td | safe }}>Published</td><td {{ tdr | safe }}>{{ publishedCount.n }}</td></tr>
          <tr {{ rowb | safe }}><td {{ td | safe }}>In Review</td><td {{ tdr | safe }}>{{ reviewCount.n }}</td></tr>
          <tr {{ rowb | safe }}><td {{ td | safe }}>Draft</td><td {{ tdr | safe }}>{{ draftCount.n }}</td></tr>
        </tbody>
      </table>
    </div>

    {# ── Authors ── #}
    <div>
      <h2 style="font-family:var(--font-headline);font-size:var(--text-md);margin-bottom:var(--space-2);">Authors</h2>
      <table {{ tbl | safe }}>
        <thead><tr {{ headb | safe }}><th {{ th | safe }}>Author</th><th {{ thr | safe }}>Role</th></tr></thead>
        <tbody>
          {% for slug, author in authors %}
          <tr {{ rowb | safe }}>
            <td {{ td | safe }}><a href="/author/{{ slug }}/">{{ author.name }}</a></td>
            <td {{ tdr | safe }}>{{ author.role }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    {# ── Projects ── #}
    <div>
      <h2 style="font-family:var(--font-headline);font-size:var(--text-md);margin-bottom:var(--space-2);">Projects</h2>
      <table {{ tbl | safe }}>
        <thead><tr {{ headb | safe }}><th {{ th | safe }}>Project</th><th {{ thr | safe }}>Entries</th></tr></thead>
        <tbody>
          <tr {{ rowb | safe }}><td {{ td | safe }}><a href="/glossary/">Glossary</a></td><td {{ tdr | safe }}>{{ collections.glossary.length }}</td></tr>
          <tr {{ rowb | safe }}><td {{ td | safe }}><a href="/bookshelf/">Recommended Reading</a></td><td {{ tdr | safe }}>{{ collections.bookshelf.length }}</td></tr>
          <tr {{ rowb | safe }}><td {{ td | safe }}><a href="/thought-experiments/">Thought Experiments</a></td><td {{ tdr | safe }}>{{ collections["thought-experiments"].length }}</td></tr>
          <tr {{ rowb | safe }}><td {{ td | safe }}><a href="/trials/">Trials of Thought</a></td><td {{ tdr | safe }}>{{ collections["trials-of-thought"].length }}</td></tr>
          <tr {{ rowb | safe }}><td {{ td | safe }}><a href="/quotes/">Quotes</a></td><td {{ tdr | safe }}>{{ quotes | length }}</td></tr>
          <tr {{ rowb | safe }}><td {{ td | safe }}><a href="/timeline/">Timeline</a></td><td {{ tdr | safe }}>{{ timeline | length }}</td></tr>
          <tr {{ rowb | safe }}><td {{ td | safe }}><a href="/music/">Songs</a></td><td {{ tdr | safe }}>{{ songs | length }}</td></tr>
          <tr {{ rowb | safe }}><td {{ td | safe }}><a href="/videos/">Videos</a></td><td {{ tdr | safe }}>{{ videos | length }}</td></tr>
          <tr {{ rowb | safe }}><td {{ td | safe }}><a href="/gallery/">Gallery</a></td><td {{ tdr | safe }}>{{ gallery | length }}</td></tr>
          <tr {{ rowb | safe }}><td {{ td | safe }}><a href="/events/">Events</a></td><td {{ tdr | safe }}>{{ events | length }}</td></tr>
          <tr {{ rowb | safe }}><td {{ td | safe }}><a href="/music/">Playlists</a></td><td {{ tdr | safe }}>{{ playlists | length }}</td></tr>
        </tbody>
      </table>
    </div>

    {# ── Library ── #}
    <div>
      <h2 style="font-family:var(--font-headline);font-size:var(--text-md);margin-bottom:var(--space-2);">Library</h2>
      <table {{ tbl | safe }}>
        <thead><tr {{ headb | safe }}><th {{ th | safe }}>Metric</th><th {{ thr | safe }}>Count</th></tr></thead>
        <tbody>
          <tr {{ rowb | safe }}><td {{ td | safe }}>Works</td><td {{ tdr | safe }}>{{ library.works | length }}</td></tr>
          <tr {{ rowb | safe }}><td {{ td | safe }}>Chapters</td><td {{ tdr | safe }}>{{ collections.libraryChapters.length }}</td></tr>
          <tr {{ rowb | safe }}><td {{ td | safe }}>Authors</td><td {{ tdr | safe }}>{{ library.authors | length }}</td></tr>
          <tr {{ rowb | safe }}><td {{ td | safe }}>Subjects</td><td {{ tdr | safe }}>{{ library.subjects | length }}</td></tr>
        </tbody>
      </table>
    </div>

    {# ── Data Collections ── #}
    <div>
      <h2 style="font-family:var(--font-headline);font-size:var(--text-md);margin-bottom:var(--space-2);">Infrastructure</h2>
      <table {{ tbl | safe }}>
        <thead><tr {{ headb | safe }}><th {{ th | safe }}>Item</th><th {{ thr | safe }}>Count</th></tr></thead>
        <tbody>
          <tr {{ rowb | safe }}><td {{ td | safe }}>RSS Feeds</td><td {{ tdr | safe }}>{{ feeds | length }}</td></tr>
          <tr {{ rowb | safe }}><td {{ td | safe }}>Changelog Entries</td><td {{ tdr | safe }}>{{ changelog | length }}</td></tr>
          <tr {{ rowb | safe }}><td {{ td | safe }}>Total Pages (build)</td><td {{ tdr | safe }}>545+</td></tr>
        </tbody>
      </table>
    </div>

  </div>

  <div class="container--prose">
    <div class="article-body">

      <h2>Recent Articles</h2>

      <ul>
        {% for article in collections.allContent | limit(10) %}
        <li>
          <a href="{{ article.url }}">{{ article.data.title }}</a>
          <span style="color:var(--color-ink-faint);font-size:var(--text-xs);">
            {{ article.data.section }} &middot; {{ article.date | readableDate }}
            {% if article.data.status == "draft" or article.data.draft %} &middot; <strong style="color:var(--color-accent);">DRAFT</strong>{% endif %}
            {% if article.data.status == "review" %} &middot; <strong style="color:var(--color-history);">IN REVIEW</strong>{% endif %}
          </span>
        </li>
        {% endfor %}
      </ul>

      <h2>Manage Content</h2>

      <p>Use <a href="https://app.pagescms.org" target="_blank" rel="noopener noreferrer">Pages CMS</a> to add and edit content without touching code. Sign in with your GitHub account to get started.</p>

    </div>
  </div>
</div>
