---
layout: base
title: Page Not Found
permalink: /404.html
eleventyExcludeFromCollections: true
---

<div class="container" style="padding-top: var(--space-16); padding-bottom: var(--space-24);">
  <div class="container--prose u-center">
    <p style="font-family: var(--font-masthead); font-size: clamp(4rem, 15vw, 10rem); line-height: 1; color: var(--color-rule-heavy); margin-bottom: var(--space-4);">404</p>
    <h1 style="font-family: var(--font-headline); font-size: var(--text-2xl); margin-bottom: var(--space-4);">Page Not Found</h1>
    <p style="color: var(--color-ink-muted); max-width: 50ch; margin-inline: auto; margin-bottom: var(--space-6);">
      The page you were looking for has moved, was renamed, or never existed. If you followed a link from another site, it may be out of date.
    </p>

    <div id="nf-suggestions" style="margin-bottom: var(--space-8);" hidden>
      <p style="font-family: var(--font-ui); font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-ink-faint); margin-bottom: var(--space-3);">Did you mean</p>
      <ul id="nf-matches" style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--space-2);"></ul>
    </div>

    <div style="display: flex; gap: var(--space-3); justify-content: center; flex-wrap: wrap; margin-bottom: var(--space-10);">
      <a href="/" class="btn">&larr; Front Page</a>
      <a href="/search/" class="btn">Search</a>
      <a href="/site-map/" class="btn">Site Map</a>
    </div>
  </div>

  <div class="container--prose">
    <h2 style="font-family: var(--font-headline); font-size: var(--text-md); text-align: center; margin-bottom: var(--space-4);">Or start somewhere new</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: var(--space-3);">
      {% for item in site.nav %}
      {% if item.collection %}
      <a href="{{ item.url }}" style="display: block; padding: var(--space-4) var(--space-5); border: 1px solid var(--color-rule); text-decoration: none;">
        <span style="font-family: var(--font-ui); font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-ink-faint); display: block; margin-bottom: var(--space-1);">Section</span>
        <span style="font-family: var(--font-headline); font-size: var(--text-sm); font-weight: 700; color: var(--color-ink);">{{ item.label }}</span>
      </a>
      {% endif %}
      {% endfor %}
    </div>

    <p style="font-family: var(--font-ui); font-size: var(--text-xs); color: var(--color-ink-faint); text-align: center; margin-top: var(--space-8);">
      Something broken? <a href="/feedback/">Tell us</a> and we'll track it down.
    </p>
  </div>
</div>

<script>
(function () {
  // "Did you mean" suggestions: fetch the search index and fuzzy-match
  // the failed URL against page titles and URLs.
  var suggestions = document.getElementById('nf-suggestions');
  var matchesEl = document.getElementById('nf-matches');
  if (!suggestions || !matchesEl) return;

  var badPath = location.pathname || '';
  if (badPath === '/404.html' || badPath === '/') return;

  // Tokenize the failed URL into words
  var terms = badPath
    .toLowerCase()
    .replace(/\.html$/, '')
    .split(/[/\-_]+/)
    .filter(function (w) { return w.length >= 3; });
  if (!terms.length) return;

  function scoreMatch(text, url) {
    var hay = (text + ' ' + url).toLowerCase();
    var score = 0;
    terms.forEach(function (t) {
      if (hay.indexOf(t) !== -1) score += t.length;
    });
    return score;
  }

  function renderMatches(results) {
    if (!results.length) return;
    matchesEl.innerHTML = results.slice(0, 5).map(function (r) {
      return '<li>' +
        '<a href="' + r.url + '" style="display:block;padding:var(--space-2) var(--space-4);border:1px solid var(--color-rule);text-decoration:none;text-align:left;transition:border-color 0.15s;" onmouseover="this.style.borderColor=\'var(--color-ink)\'" onmouseout="this.style.borderColor=\'var(--color-rule)\'">' +
          '<span style="font-family:var(--font-headline);font-size:var(--text-sm);font-weight:600;color:var(--color-ink);display:block;">' + escapeHtml(r.title) + '</span>' +
          '<span style="font-family:var(--font-ui);font-size:var(--text-xs);color:var(--color-ink-faint);">' + escapeHtml(r.url) + '</span>' +
        '</a>' +
      '</li>';
    }).join('');
    suggestions.hidden = false;
  }

  function escapeHtml(s) { var d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }

  // Try Pagefind first — it's already loaded for search
  (async function () {
    try {
      var pf = await import('/pagefind/pagefind.js');
      await pf.options({ excerptLength: 0 });
      var q = terms.join(' ');
      var s = await pf.search(q);
      var items = await Promise.all(s.results.slice(0, 10).map(function (r) { return r.data(); }));
      var scored = items.map(function (item) {
        return { title: item.meta && item.meta.title || 'Untitled', url: item.url, score: scoreMatch(item.meta && item.meta.title || '', item.url) };
      }).filter(function (r) { return r.score > 0; }).sort(function (a, b) { return b.score - a.score; });
      renderMatches(scored);
    } catch (e) { /* Pagefind not available; fail silently */ }
  })();
})();
</script>
