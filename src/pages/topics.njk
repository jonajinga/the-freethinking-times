---
layout: base
title: Topics
description: "Browse all topics covered in {{ site.title }} — tag clouds, related topics, and the most-written-about subjects."
permalink: /topics/
---

<div class="container" style="padding-top: var(--space-10); padding-bottom: var(--space-20);">

  <header style="margin-bottom: var(--space-10); padding-bottom: var(--space-6); border-bottom: 3px solid var(--color-ink);">
    <h1 style="font-family: var(--font-masthead); font-size: clamp(1.8rem, 5vw, 3.815rem); margin-bottom: var(--space-4);">Topics</h1>
    <p style="font-size: var(--text-lg); color: var(--color-ink-muted); font-style: italic; max-width: 55ch;">
      Every subject covered across {{ site.title }}, sized by how often we have written about it. Each topic links to its own archive.
    </p>
  </header>

  {% set topics = collections.allContent | topicStats(6) %}
  {% set maxCount = (topics[0].count if topics.length else 1) %}

  {# ── Cloud view ── #}
  <section style="margin-bottom: var(--space-12);">
    <h2 style="font-family:var(--font-headline);font-size:var(--text-lg);margin-bottom:var(--space-4);">Topic cloud</h2>
    <div style="display:flex;flex-wrap:wrap;gap:var(--space-3);line-height:1.5;">
      {% for t in topics %}
      {% set weight = (t.count / maxCount) %}
      {% set size = 0.85 + weight * 0.9 %}
      <a href="/topics/{{ t.tag | slugify }}/"
        style="font-family:var(--font-headline);font-size:{{ size }}rem;color:var(--color-ink);text-decoration:none;padding:var(--space-1) var(--space-3);border:1px solid var(--color-rule);border-radius:var(--radius-md);transition:all var(--transition-fast);"
        onmouseover="this.style.borderColor='var(--color-ink)';this.style.background='var(--color-bg-alt)';"
        onmouseout="this.style.borderColor='var(--color-rule)';this.style.background='transparent';"
        title="{{ t.count }} article{% if t.count != 1 %}s{% endif %}">
        {{ t.tag }}
        <span style="font-size:0.65em;color:var(--color-ink-faint);margin-left:var(--space-1);">{{ t.count }}</span>
      </a>
      {% endfor %}
    </div>
  </section>

  {# ── Top topics with related clusters ── #}
  <section>
    <h2 style="font-family:var(--font-headline);font-size:var(--text-lg);margin-bottom:var(--space-4);">Most covered topics</h2>
    <p style="font-family:var(--font-body);font-size:var(--text-sm);color:var(--color-ink-muted);max-width:55ch;margin-bottom:var(--space-6);">
      Our most frequent subjects, with the topics that most often appear alongside them.
    </p>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:var(--space-6);">
      {% for t in topics | limit(12) %}
      <article style="border:1px solid var(--color-rule);padding:var(--space-5) var(--space-6);display:flex;flex-direction:column;gap:var(--space-3);">
        <header style="display:flex;justify-content:space-between;align-items:baseline;gap:var(--space-3);">
          <a href="/topics/{{ t.tag | slugify }}/" style="font-family:var(--font-headline);font-size:var(--text-md);font-weight:700;color:var(--color-ink);text-decoration:none;">{{ t.tag }}</a>
          <span style="font-family:var(--font-ui);font-size:var(--text-xs);color:var(--color-ink-faint);">{{ t.count }} article{% if t.count != 1 %}s{% endif %}</span>
        </header>
        {% if t.related.length %}
        <div>
          <p style="font-family:var(--font-ui);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--color-ink-faint);margin:0 0 var(--space-2);">Related topics</p>
          <div style="display:flex;flex-wrap:wrap;gap:var(--space-1);">
            {% for r in t.related %}
            <a href="/topics/{{ r.tag | slugify }}/" style="font-family:var(--font-ui);font-size:var(--text-xs);color:var(--color-link);text-decoration:none;border:1px solid var(--color-rule);padding:1px var(--space-2);border-radius:var(--radius-sm);">{{ r.tag }}</a>
            {% endfor %}
          </div>
        </div>
        {% endif %}
        {% if t.top.length %}
        <div>
          <p style="font-family:var(--font-ui);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--color-ink-faint);margin:0 0 var(--space-2);">Latest</p>
          <ul style="list-style:none;padding:0;margin:0;">
            {% for item in t.top %}
            <li style="padding:var(--space-1) 0;">
              <a href="{{ item.url }}" style="font-family:var(--font-body);font-size:var(--text-sm);color:var(--color-ink);text-decoration:none;line-height:var(--leading-snug);">{{ item.data.title }}</a>
            </li>
            {% endfor %}
          </ul>
        </div>
        {% endif %}
      </article>
      {% endfor %}
    </div>
  </section>

  {% if topics.length == 0 %}
  <p style="font-family:var(--font-ui);font-size:var(--text-sm);color:var(--color-ink-faint);font-style:italic;">No topics tagged yet.</p>
  {% endif %}

</div>
