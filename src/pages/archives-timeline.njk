---
layout: base
title: Archive Timeline
description: Every article published in The Freethinking Times, in chronological order. Narrow by author, section, subsection, or topic.
permalink: /archives/timeline/
eleventyExcludeFromCollections: true
---

<div class="container archive-timeline" style="padding-top: var(--space-10); padding-bottom: var(--space-20);">

  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <ol class="breadcrumbs__list">
      <li class="breadcrumbs__item"><a class="breadcrumbs__link" href="/">Home</a></li>
      <li class="breadcrumbs__item"><a class="breadcrumbs__link" href="/archives/">Archives</a></li>
      <li class="breadcrumbs__item breadcrumbs__item--current" aria-current="page">Timeline</li>
    </ol>
  </nav>

  <header class="archive-timeline__header" style="text-align:center;padding-bottom:var(--space-6);border-bottom:3px solid var(--color-ink);margin-bottom:var(--space-8);">
    <p class="archive-timeline__kicker" style="font-family:var(--font-ui);font-size:var(--text-xs);font-weight:700;text-transform:uppercase;letter-spacing:0.16em;color:var(--color-accent);margin:0 0 var(--space-2);">Chronological view</p>
    <h1 id="at-title" style="font-family:var(--font-masthead);font-size:clamp(1.8rem,5vw,3.815rem);margin:0 0 var(--space-3);">Archive Timeline</h1>
    <p id="at-lede" style="color:var(--color-ink-muted);font-size:var(--text-md);font-style:italic;max-width:48ch;margin:0 auto;"></p>
    <div style="display:flex;gap:var(--space-3);justify-content:center;margin-top:var(--space-5);flex-wrap:wrap;">
      <a id="at-view-showcase" href="/archives/showcase/" class="btn btn--accent">View as showcase &rarr;</a>
      <a href="/archives/" class="btn">Back to archives</a>
    </div>
  </header>

  <div id="at-controls" class="archive-timeline__controls" style="display:flex;gap:var(--space-3);align-items:center;flex-wrap:wrap;margin-bottom:var(--space-6);">
    <span id="at-filter-chip" class="archive-timeline__chip" hidden style="font-family:var(--font-ui);font-size:var(--text-xs);font-weight:700;text-transform:uppercase;letter-spacing:0.08em;padding:var(--space-2) var(--space-3);background:var(--color-ink);color:var(--color-bg);display:inline-flex;align-items:center;gap:var(--space-2);"></span>
    <a id="at-clear-filter" href="/archives/timeline/" class="btn" hidden style="font-size:var(--text-xs);">Clear filter</a>
    <span id="at-count" style="font-family:var(--font-ui);font-size:var(--text-xs);color:var(--color-ink-faint);margin-left:auto;"></span>
  </div>

  <div id="at-list" class="archive-timeline__list" data-pagefind-ignore></div>

  <p id="at-empty" class="archive-timeline__empty" hidden style="text-align:center;font-family:var(--font-ui);font-style:italic;color:var(--color-ink-muted);padding:var(--space-12) 0;">No articles match this filter.</p>

</div>

<style>
.archive-timeline__list {
  display: flex;
  flex-direction: column;
  gap: var(--space-5);
  padding-left: 0;
  list-style: none;
}
.archive-timeline__year {
  position: relative;
  display: flex;
  align-items: baseline;
  gap: var(--space-4);
  padding-bottom: var(--space-2);
  margin: var(--space-8) 0 var(--space-3);
  border-bottom: 2px solid var(--color-ink);
}
.archive-timeline__year:first-child { margin-top: 0; }
.archive-timeline__year-n {
  font-family: var(--font-masthead, var(--font-headline));
  font-size: clamp(2rem, 5vw, 3rem);
  font-weight: 700;
  color: var(--color-ink);
  line-height: 1;
}
.archive-timeline__year-count {
  font-family: var(--font-ui);
  font-size: var(--text-xs);
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--color-ink-faint);
  margin-left: auto;
}
.archive-timeline__month {
  display: block;
  font-family: var(--font-ui);
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: var(--color-accent);
  margin: var(--space-5) 0 var(--space-2);
}
.archive-timeline__item {
  display: grid;
  grid-template-columns: 90px 1fr;
  gap: var(--space-4);
  padding: var(--space-3) 0;
  border-bottom: 1px solid var(--color-rule);
  text-decoration: none;
  color: var(--color-ink);
  transition: background var(--transition-fast);
}
.archive-timeline__item:hover {
  background: var(--color-bg-alt);
}
.archive-timeline__item-date {
  font-family: var(--font-ui);
  font-size: 0.78rem;
  color: var(--color-ink-faint);
  font-variant-numeric: tabular-nums;
  padding-top: 4px;
}
.archive-timeline__item-body { min-width: 0; }
.archive-timeline__item-section {
  font-family: var(--font-ui);
  font-size: 0.66rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--color-accent);
  display: block;
  margin-bottom: 2px;
}
.archive-timeline__item-title {
  font-family: var(--font-headline);
  font-weight: 700;
  font-size: var(--text-md);
  line-height: var(--leading-snug);
  color: var(--color-ink);
  margin: 0 0 2px;
}
.archive-timeline__item:hover .archive-timeline__item-title { color: var(--color-accent); }
.archive-timeline__item-meta {
  font-family: var(--font-ui);
  font-size: 0.78rem;
  color: var(--color-ink-muted);
  margin: 0;
}
@media (max-width: 640px) {
  .archive-timeline__item { grid-template-columns: 1fr; gap: var(--space-1); }
  .archive-timeline__item-date { padding-top: 0; }
}
</style>

<script id="at-data" type="application/json">
{%- set _articles = [] -%}
{%- for a in collections.allContent -%}
  {%- set entry = {
    url: a.url,
    title: a.data.title,
    date: a.data.date | isoDate,
    section: a.data.section,
    sectionSlug: a.data.section | slugify,
    subsection: a.data.subsection,
    author: a.data.author,
    authorName: (authors[a.data.author].name if a.data.author and authors[a.data.author] else (a.data.authorName or '')),
    tags: a.data.tags | rejectattr('post')
  } -%}
  {%- set _articles = _articles.concat([entry]) -%}
{%- endfor -%}
{{ _articles | dump | safe }}
</script>

<script>
(function () {
  var data = [];
  try { data = JSON.parse(document.getElementById('at-data').textContent); } catch (e) {}

  var params = new URLSearchParams(location.search);
  var author = params.get('author') || '';
  var section = (params.get('section') || '').toLowerCase();
  var subsection = (params.get('subsection') || '').toLowerCase();
  var topic = (params.get('topic') || '').toLowerCase();

  function normSlug(s) { return (s || '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, ''); }

  var filtered = data.filter(function (a) {
    if (author && a.author !== author) return false;
    if (section && normSlug(a.section) !== section && normSlug(a.sectionSlug) !== section) return false;
    if (subsection && normSlug(a.subsection) !== subsection) return false;
    if (topic) {
      var tags = (a.tags || []).map(function (t) { return normSlug(t); });
      if (tags.indexOf(topic) === -1) return false;
    }
    return true;
  }).sort(function (a, b) {
    return new Date(b.date) - new Date(a.date);
  });

  // Title + lede
  var titleEl = document.getElementById('at-title');
  var ledeEl = document.getElementById('at-lede');
  var chipEl = document.getElementById('at-filter-chip');
  var clearEl = document.getElementById('at-clear-filter');
  var filterLabel = '';
  var filterParams = [];
  if (author) {
    var authorName = (data.find(function (x) { return x.author === author; }) || {}).authorName || author;
    filterLabel = 'Articles by ' + authorName;
    titleEl.textContent = filterLabel;
    filterParams.push('author=' + encodeURIComponent(author));
  } else if (topic) {
    filterLabel = 'Topic: ' + topic;
    titleEl.textContent = 'Topic \u2014 ' + topic;
    filterParams.push('topic=' + encodeURIComponent(topic));
  } else if (section) {
    filterLabel = 'Section: ' + section + (subsection ? ' \u203a ' + subsection : '');
    titleEl.textContent = section.charAt(0).toUpperCase() + section.slice(1) + (subsection ? ' \u203a ' + subsection : '') + ' Timeline';
    filterParams.push('section=' + encodeURIComponent(section));
    if (subsection) filterParams.push('subsection=' + encodeURIComponent(subsection));
  }
  if (filterLabel) {
    chipEl.hidden = false;
    chipEl.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="22" y1="12" x2="2" y2="12"/><path d="M5.45 5.11 2 12l3.45 6.89A2 2 0 0 0 7.24 20h12.47a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2H7.24a2 2 0 0 0-1.79 1.11z"/></svg>' + filterLabel;
    clearEl.hidden = false;
  }
  ledeEl.textContent = filtered.length + ' ' + (filtered.length === 1 ? 'article' : 'articles') + ', most recent first.';
  document.getElementById('at-count').textContent = filtered.length + ' ' + (filtered.length === 1 ? 'article' : 'articles');

  // Showcase link should preserve filters
  var showcase = document.getElementById('at-view-showcase');
  if (filterParams.length) showcase.href = '/archives/showcase/?' + filterParams.join('&');

  // Render grouped by year/month
  var listEl = document.getElementById('at-list');
  if (!filtered.length) {
    document.getElementById('at-empty').hidden = false;
    return;
  }
  var MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  var currentYear = null, currentMonth = null, currentGroupEl = null, yearCount = 0, yearEl = null;
  var yearCounts = {};
  filtered.forEach(function (a) {
    var y = new Date(a.date).getUTCFullYear();
    yearCounts[y] = (yearCounts[y] || 0) + 1;
  });
  filtered.forEach(function (a) {
    var d = new Date(a.date);
    var y = d.getUTCFullYear();
    var m = d.getUTCMonth();
    if (y !== currentYear) {
      currentYear = y; currentMonth = null;
      yearEl = document.createElement('div');
      yearEl.className = 'archive-timeline__year';
      yearEl.innerHTML =
        '<span class="archive-timeline__year-n">' + y + '</span>' +
        '<span class="archive-timeline__year-count">' + yearCounts[y] + ' ' + (yearCounts[y] === 1 ? 'article' : 'articles') + '</span>';
      listEl.appendChild(yearEl);
    }
    if (m !== currentMonth) {
      currentMonth = m;
      var monthEl = document.createElement('p');
      monthEl.className = 'archive-timeline__month';
      monthEl.textContent = MONTHS[m];
      listEl.appendChild(monthEl);
    }
    var item = document.createElement('a');
    item.className = 'archive-timeline__item';
    item.href = a.url;
    var dateStr = d.toLocaleDateString(undefined, { month: 'short', day: 'numeric', timeZone: 'UTC' });
    item.innerHTML =
      '<span class="archive-timeline__item-date">' + dateStr + '</span>' +
      '<div class="archive-timeline__item-body">' +
        (a.section ? '<span class="archive-timeline__item-section">' + a.section + (a.subsection ? ' \u203a ' + a.subsection : '') + '</span>' : '') +
        '<h2 class="archive-timeline__item-title">' + a.title + '</h2>' +
        (a.authorName ? '<p class="archive-timeline__item-meta">' + a.authorName + '</p>' : '') +
      '</div>';
    listEl.appendChild(item);
  });
})();
</script>
