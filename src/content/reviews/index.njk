---
layout: base
title: Reviews
description: Book, film, podcast, and documentary reviews from The Freethinking Times.
permalink: /reviews/
---

<div class="container" style="padding-top: var(--space-10); padding-bottom: var(--space-20);">

  <header style="padding-bottom: var(--space-6); border-bottom: 3px solid var(--color-ink); margin-bottom: var(--space-10);">
    <h1 style="font-family: var(--font-masthead); font-size: clamp(1.8rem, 5vw, 3.815rem); margin-bottom: var(--space-4);">Reviews</h1>
    <p style="color: var(--color-ink-muted); font-size: var(--text-md); font-style: italic; max-width: 50ch;">
      Honest assessments of books, films, podcasts, and documentaries that matter to the freethinking tradition.
    </p>
  </header>

  {% set reviews = collections.reviews | reverse %}

  {% if reviews.length == 0 %}
  <p style="font-family:var(--font-ui);font-size:var(--text-sm);color:var(--color-ink-faint);font-style:italic;">No reviews published yet. Check back soon.</p>
  {% endif %}

  <div style="display:grid;gap:var(--space-8);">
    {% for item in reviews %}
    <article style="border-bottom:1px solid var(--color-rule);padding-bottom:var(--space-8);">
      <div style="display:flex;align-items:baseline;gap:var(--space-3);margin-bottom:var(--space-2);">
        {% if item.data.mediaType %}<span style="font-family:var(--font-ui);font-size:var(--text-xs);font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--color-reviews);">{{ item.data.mediaType }}</span>{% endif %}
        {% if item.data.rating %}<span style="font-family:var(--font-ui);font-size:var(--text-xs);color:var(--color-ink-faint);">{{ "★" | repeat(item.data.rating) }}{{ "☆" | repeat(5 - item.data.rating) }}</span>{% endif %}
      </div>
      <h2 style="font-family:var(--font-headline);font-size:var(--text-lg);font-weight:700;margin:0 0 var(--space-2);line-height:var(--leading-snug);">
        <a href="{{ item.url }}" style="color:var(--color-ink);text-decoration:none;">{{ item.data.title }}</a>
      </h2>
      {% if item.data.creator %}<p style="font-family:var(--font-ui);font-size:var(--text-sm);color:var(--color-ink-muted);margin:0 0 var(--space-2);">{{ item.data.creator }}{% if item.data.year %} ({{ item.data.year }}){% endif %}</p>{% endif %}
      <p style="font-family:var(--font-body);font-size:var(--text-sm);color:var(--color-ink-muted);line-height:1.6;margin:0;">{{ item.data.description }}</p>
    </article>
    {% endfor %}
  </div>

</div>
