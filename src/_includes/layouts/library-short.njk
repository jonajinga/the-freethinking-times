---
layout: layouts/base.njk
---
{% block head %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Book",
  "name": "{{ workTitle }}",
  "author": {
    "@type": "Person",
    "name": "{{ author }}"
  },
  "datePublished": "{{ originalPublication }}",
  "inLanguage": "{{ originalLanguage or 'en' }}",
  "isAccessibleForFree": true,
  "url": "{{ site.url }}{{ page.url }}"
}
</script>
{% endblock %}
{# Context div — read by library.js. No chapter slug since this is a standalone short work. #}
<div id="library-context"
     data-work-slug="{{ workSlug }}"
     data-work-title="{{ workTitle | escape }}"
     data-chapter-slug="{{ chapterSlug or workSlug }}"
     data-chapter-title="{{ title }}"
     hidden></div>
{# Context for annotations.js #}
<div id="annotations-context" data-page-slug="{{ workSlug }}" data-page-url="{{ page.url }}" data-page-title="{{ workTitle | escape }}: {{ title | escape }}" hidden></div>

{# Inline script: apply focus mode before paint to avoid layout shift #}
<script>document.documentElement.classList.add('is-library-reading');(function(){if(localStorage.getItem((window.__PREFIX||'tft')+'-focus')==='on')document.documentElement.setAttribute('data-focus-mode','on');}());</script>

{# ── Reading progress bar ── #}
<div class="library-reading-progress" aria-hidden="true">
  <div class="library-reading-progress__bar" id="reading-progress-bar"></div>
</div>

{# ── Sticky reading header ── #}
<header class="library-reading-header">
  <a class="library-reading-header__back" href="/library/">&larr; Library</a>
  <span class="library-reading-header__title">{{ title }}</span>
</header>

{# ── Body wrapper ── #}
<div class="library-body-wrapper">

  <p class="library-body-chapter-info">
    {% if era %}<span>{{ era }}</span>{% endif %}
    {% if author %}&nbsp;&mdash;&nbsp;<span>{{ author }}</span>{% endif %}
  </p>

  <h1 class="library-body__heading">{{ title }}</h1>
  {% if subtitle %}<p class="library-body-chapter-info">{{ subtitle }}</p>{% endif %}

  <p class="library-body-meta">
    <span>{{ content | wordCount }} words</span>
    <span aria-hidden="true">&middot;</span>
    <span>{{ content | readingTime }}</span>
  </p>

  {# ── Reader tools (Save, Share, Listen, Focus, Reading, Download, Print, Cite) ── #}
  {% include "partials/library-reader-tools.njk" %}

  {# TTS control bar — shown by JS when reading starts #}
  <div id="tts-controls" class="tts-controls" hidden>
    <div class="tts-controls__inner">
      <button id="tts-pause-btn" class="tts-controls__btn" type="button" aria-label="Pause">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
      </button>
      <button id="tts-stop-btn" class="tts-controls__btn" type="button" aria-label="Stop">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><rect x="4" y="4" width="16" height="16"/></svg>
      </button>
      <span class="tts-controls__divider" aria-hidden="true"></span>
      <div class="tts-controls__speed" role="group" aria-label="Speed">
        <button class="tts-speed-btn" data-rate="0.75" type="button">0.75×</button>
        <button class="tts-speed-btn is-active"  data-rate="1"    type="button">1×</button>
        <button class="tts-speed-btn" data-rate="1.25" type="button">1.25×</button>
        <button class="tts-speed-btn" data-rate="1.5"  type="button">1.5×</button>
        <button class="tts-speed-btn" data-rate="2"    type="button">2×</button>
      </div>
      <select id="tts-voice-select" class="tts-controls__voice-select" aria-label="Voice"></select>
    </div>
  </div>

  {# Cite overlay + modal #}
  <div id="cite-overlay" class="cite-overlay" hidden aria-hidden="true"></div>
  <div id="cite-modal" class="cite-modal" hidden role="dialog" aria-modal="true" aria-labelledby="cite-modal-title">
    <div class="cite-modal__inner">
      <div class="cite-modal__header">
        <p class="cite-modal__title" id="cite-modal-title">Cite This Work</p>
        <button id="cite-close" class="cite-modal__close" type="button" aria-label="Close citation panel">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <div class="cite-modal__tabs" role="tablist" aria-label="Citation format">
        <button class="cite-tab is-active" data-format="apa"     role="tab" aria-selected="true"  type="button">APA 7th</button>
        <button class="cite-tab"           data-format="mla"     role="tab" aria-selected="false" type="button">MLA 9th</button>
        <button class="cite-tab"           data-format="chicago" role="tab" aria-selected="false" type="button">Chicago 17th</button>
      </div>
      <div class="cite-modal__body">
        <p id="cite-text" class="cite-modal__text"></p>
      </div>
      <button id="cite-copy-btn" class="cite-modal__copy-btn" type="button">Copy citation</button>
    </div>
  </div>

  <div class="library-body article-body" data-pagefind-body>
    <div aria-hidden="true" style="display:none">
      <span data-pagefind-meta="section">Library</span>
      <span data-pagefind-meta="work">{{ workTitle }}</span>
      <span data-pagefind-meta="author">{{ author }}</span>
    </div>
    {{ content | safe }}
  </div>

</div>{# /.library-body-wrapper #}

<div class="reading-floats" id="reading-floats" aria-hidden="true">
  <span class="reading-pct" id="reading-pct"></span>
  <button class="back-to-top" id="back-to-top" type="button" aria-label="Back to top">↑</button>
</div>

<div id="print-footnotes" class="print-footnotes" aria-hidden="true"></div>
<div id="print-citations" class="print-citations" aria-hidden="true"></div>

<footer class="print-footer" aria-hidden="true">
  <span>{{ site.title }} — {{ site.url }}{{ page.url }}</span>
  <span>{{ workTitle or title }} by {{ author }}</span>
</footer>

{# ── Within-chapter floating TOC (≥1200px; populated by progress.js) ── #}
<div class="library-toc-float" id="toc-widget" hidden>
  <p class="library-toc-float__title">On this page</p>
  <nav id="toc-nav" aria-label="Section headings"></nav>
</div>

{# ── Panel overlay ── #}
<div class="library-panel-overlay" aria-hidden="true"></div>

{# ── Reading panel ── #}
<aside id="library-panel" class="library-panel" aria-hidden="true" aria-label="Reading panel">
  <div class="library-panel__header">
    <span style="font-family:var(--font-ui);font-size:var(--text-sm);font-weight:700;">Reader</span>
    <button class="library-panel__close" aria-label="Close panel">&times;</button>
  </div>

  <div class="library-panel__tabs" role="tablist" style="justify-content:center;">
    <button class="library-panel__tab" role="tab" aria-selected="true" aria-label="Contents" title="Contents" data-target="panel-toc">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
    </button>
    <button class="library-panel__tab" role="tab" aria-selected="false" aria-label="Highlights" title="Highlights" data-target="panel-highlights">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
    </button>
    <button class="library-panel__tab" role="tab" aria-selected="false" aria-label="Notes" title="Notes" data-target="panel-notes">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
    </button>
    <button class="library-panel__tab" role="tab" aria-selected="false" aria-label="Bookmarks" title="Bookmarks" data-target="panel-bookmarks">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
    </button>
    <button class="library-panel__tab" role="tab" aria-selected="false" aria-label="Footnotes" title="Footnotes" data-target="panel-footnotes">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 6h13"/><path d="M8 12h13"/><path d="M8 18h13"/><text x="2" y="9" font-size="7" font-weight="700" fill="currentColor" stroke="none">1</text><text x="2" y="15" font-size="7" font-weight="700" fill="currentColor" stroke="none">2</text><text x="2" y="21" font-size="7" font-weight="700" fill="currentColor" stroke="none">3</text></svg>
    </button>
    <button class="library-panel__tab" role="tab" aria-selected="false" aria-label="Citation formats" title="Cite" data-target="panel-cite-inline">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M11.192 15.757c0-.88-.23-1.618-.69-2.217-.326-.412-.768-.683-1.327-.812-.55-.128-1.07-.137-1.54-.028-.16-.95.1-1.685.54-2.293.44-.6 1.05-1.05 1.83-1.343.78-.295 1.56-.43 2.34-.43v-1.52c-.976 0-1.94.16-2.886.48-.95.32-1.8.824-2.556 1.51-.755.685-1.347 1.54-1.78 2.563-.432 1.025-.65 2.218-.65 3.58 0 1.36.22 2.47.65 3.33.432.86 1.02 1.5 1.76 1.92.74.42 1.57.63 2.48.63.97 0 1.79-.22 2.46-.66.67-.44 1.17-1.03 1.5-1.77.33-.74.5-1.55.5-2.44zm9 0c0-.88-.23-1.618-.69-2.217-.326-.42-.77-.692-1.327-.817-.56-.124-1.074-.132-1.54-.022-.16-.95.1-1.685.54-2.294.44-.606 1.05-1.056 1.83-1.35.78-.294 1.56-.43 2.34-.43v-1.52c-.976 0-1.94.16-2.886.48-.95.32-1.8.825-2.556 1.51-.755.686-1.347 1.54-1.78 2.565-.432 1.022-.65 2.216-.65 3.578 0 1.36.22 2.47.65 3.33.432.86 1.02 1.5 1.76 1.92.74.42 1.57.63 2.48.63.97 0 1.79-.22 2.46-.66.67-.44 1.17-1.03 1.5-1.77.33-.74.5-1.55.5-2.44z"/></svg>
    </button>
    <button class="library-panel__tab" role="tab" aria-selected="false" aria-label="Display settings" title="Display" data-target="panel-display">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/><line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/></svg>
    </button>
    <span style="flex:1;"></span>
    <div class="library-panel__export-wrap" style="position:relative;">
      <button class="library-panel__tab" type="button" aria-label="Export notes" title="Export" onclick="var m=this.nextElementSibling;m.hidden=!m.hidden;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      </button>
      <div hidden class="library-panel__export-menu">
        <button class="library-panel__export-item" type="button" onclick="if(window.__exportPanelNotes)window.__exportPanelNotes('txt');this.parentElement.hidden=true;">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          Plain text
        </button>
        <button class="library-panel__export-item" type="button" onclick="if(window.__exportPanelNotes)window.__exportPanelNotes('md');this.parentElement.hidden=true;">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="12" y2="17"/></svg>
          Markdown
        </button>
        <button class="library-panel__export-item" type="button" onclick="if(window.__exportPanelNotes)window.__exportPanelNotes('json');this.parentElement.hidden=true;">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          JSON
        </button>
        <button class="library-panel__export-item" type="button" onclick="if(window.__printPanelNotes)window.__printPanelNotes();this.parentElement.hidden=true;">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
          Print / PDF
        </button>
      </div>
    </div>
  </div>

  <div class="library-panel__body">
    {# TOC — single item for short works #}
    <div id="panel-toc" class="library-panel__section" aria-hidden="false">
      <a class="library-toc-item" href="#" aria-current="page">
        <span class="library-toc-item__number">1.</span>
        {{ title }}
      </a>
    </div>

    {# Highlights tab #}
    <div id="panel-highlights" class="library-panel__section" aria-hidden="true" data-print-label="Highlights"></div>

    {# Notes tab #}
    <div id="panel-notes" class="library-panel__section" aria-hidden="true" data-print-label="Notes"></div>

    {# Bookmarks tab #}
    <div id="panel-bookmarks" class="library-panel__section" aria-hidden="true" data-print-label="Bookmarks"></div>

    {# Footnotes tab — populated by footnotes.js #}
    <div id="panel-footnotes" class="library-panel__section" aria-hidden="true" data-print-label="Footnotes"></div>

    {# Cite tab — populated by cite-inline.js #}
    <div id="panel-cite-inline" class="library-panel__section" aria-hidden="true"></div>

    {# Display tab — reading-settings-panel moved here by reader-panel-migrate.js #}
    <div id="panel-display" class="library-panel__section" aria-hidden="true">
      <div id="reader-panel-slot-display"></div>
    </div>
  </div>

  <div class="library-panel__footer-links">
    <button id="ann-bookmark-btn" class="library-panel__footer-btn" type="button" aria-label="Bookmark current reading position">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
      <span>Bookmark this spot</span>
    </button>
  </div>
</aside>

{# ── Annotation toolbar ── #}
<div id="annotation-toolbar" class="annotation-toolbar" role="toolbar" aria-label="Reader tools">
  <div class="annotation-toolbar__main">
    <button class="annotation-toolbar__btn library-panel-toggle" type="button" aria-label="Open Reader panel" aria-controls="library-panel" aria-expanded="false" title="Reader">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 6h16M4 12h16M4 18h10"/></svg>
    </button>
    <button id="ann-highlight-btn" class="annotation-toolbar__btn annotation-toolbar__btn--needs-selection" type="button" aria-label="Highlight selection" title="Highlight">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
    </button>
    <button id="ann-annotate-btn" class="annotation-toolbar__btn annotation-toolbar__btn--needs-selection" type="button" aria-label="Add note" title="Note">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
    </button>
    <div id="ann-listen-slot" class="annotation-toolbar__slot"></div>
    <div id="ann-focus-slot" class="annotation-toolbar__slot"></div>
    <div id="ann-save-slot" class="annotation-toolbar__slot"></div>
    <button id="ann-share-btn" class="annotation-toolbar__btn" type="button" aria-label="Share, download, print" aria-controls="ann-share-popover" aria-expanded="false" title="Share, download, print">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
    </button>
  </div>

  <div id="annotation-toolbar-music" class="annotation-toolbar__music"></div>
</div>

<div id="ann-share-popover" class="ann-share-popover" hidden role="menu" aria-labelledby="ann-share-btn">
  <p class="ann-share-popover__subhead">Share</p>
  <div id="ann-share-slot"></div>
  <p class="ann-share-popover__subhead">Download</p>
  <div id="ann-download-slot"></div>
  <p class="ann-share-popover__subhead">Print / PDF</p>
  <button class="ann-share-popover__item" type="button" data-print="article">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
    Text only
  </button>
  <button class="ann-share-popover__item" type="button" data-print="article-with-notes">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/><line x1="9" y1="11" x2="15" y2="11"/><line x1="9" y1="14" x2="13" y2="14"/></svg>
    Text with notes &amp; highlights
  </button>
  <button class="ann-share-popover__item" type="button" data-print="notes-only"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>Notes &amp; highlights only</button>
</div>

{% block scripts %}
<script src="/assets/js/progress.js?v={{ buildTime }}" defer></script>
<script src="/assets/js/reading-list.js?v={{ buildTime }}" defer></script>
<script src="/assets/js/download.js?v={{ buildTime }}" defer></script>
<script src="/assets/js/reading-settings.js?v={{ buildTime }}" defer></script>
<script src="/assets/js/library.js?v={{ buildTime }}" defer></script>
<script src="/assets/js/annotations.js?v={{ buildTime }}" defer></script>
{% endblock %}
