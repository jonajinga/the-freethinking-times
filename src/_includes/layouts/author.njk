---
layout: layouts/base.njk
---

<div class="container" style="padding-top: var(--space-10); padding-bottom: var(--space-16);" data-pagefind-body>
  <span data-pagefind-filter="section" hidden>Authors</span>

  {% set authorData = authors[authorSlug] %}
  {% include "partials/author-hero.njk" %}

  {% if authorData.bioLong %}
  <div class="author-bio-long">
    {{ authorData.bioLong | safe }}
  </div>
  {% endif %}

  <div class="section-grid">
    <div class="section-grid__main">

      {% set authorArticles = collections.allContent | where("author", authorSlug) %}
      <p style="font-family: var(--font-ui); font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-ink-faint); border-bottom: 1px solid var(--color-rule); padding-bottom: var(--space-3); margin-bottom: var(--space-6);">
        Articles by {{ title }}{% if authorArticles.length %} ({{ authorArticles.length }}){% endif %}
      </p>

      {% if authorArticles.length == 0 %}
      <p style="color: var(--color-ink-muted); font-style: italic;">No articles published yet.</p>
      {% else %}
      <ul class="article-list" role="list">
        {% for item in authorArticles %}
        <li class="article-list__item">
          {% set article = item %}
          {% set size = "sm" %}
          {% include "partials/article-card.njk" %}
        </li>
        {% endfor %}
      </ul>
      {% endif %}

    </div>

    <aside class="section-grid__sidebar">
      <div class="sidebar-widget">
        <p class="sidebar-widget__title">All Contributors</p>
        <ul style="list-style: none; padding: 0;">
          {% for slug, a in authors %}
          <li style="padding: var(--space-2) 0; border-bottom: 1px solid var(--color-rule);">
            <a href="/author/{{ slug }}/"
               style="font-family: var(--font-ui); font-size: var(--text-sm); {% if slug == authorSlug %}color: var(--color-ink); font-weight: 700;{% else %}color: var(--color-ink-muted);{% endif %} text-decoration: none;">
              {{ a.name }}
            </a>
          </li>
          {% endfor %}
        </ul>
      </div>
    </aside>

  </div>
</div>
