---
layout: layouts/base.njk
---

<div class="container front-page">

  {# ─── Lead / Hero ─────────────────────────────────────────── #}
  <section class="front-hero" aria-label="Lead stories">
    {% set leadStory = collections.featured | first or collections.allContent | first %}
    {% if leadStory %}
    {% set article = leadStory %}
    {% set size = "lg" %}
    {% set showImage = true %}
    {% include "partials/article-card.njk" %}
    {% endif %}
  </section>

  {# ─── Secondary Stories ────────────────────────────────────── #}
  {% set secondaryStories = collections.allContent | limit(4) %}
  {% if secondaryStories.length > 1 %}
  <section class="front-secondary" aria-label="More stories">
    {% for item in secondaryStories %}
    {% if not loop.first %}
    {% set article = item %}
    {% set size = "sm" %}
    {% include "partials/article-card.njk" %}
    {% endif %}
    {% endfor %}
  </section>
  {% endif %}

  {# ─── Section Strips ───────────────────────────────────────── #}
  {% set frontSections = ["opinion", "analysis", "history"] %}
  {% for sectionKey in frontSections %}
  {% set sectionItems = collections[sectionKey] | limit(3) %}
  {% if sectionItems and sectionItems.length > 0 %}
  <section class="front-section-strip" aria-label="{{ sectionKey | title }} section">

    {# Section label column #}
    <div class="front-section-strip__label">
      <a href="/{{ sectionKey }}/"
         class="section-badge section-badge--{{ sectionKey }}"
         style="font-size: var(--text-md); display: block; margin-bottom: var(--space-3);">
        {{ sectionKey | replace("-", " ") | title }}
      </a>
      <p style="font-size: var(--text-sm); color: var(--color-ink-muted); font-style: italic; line-height: var(--leading-normal);">
        {{ site.sections[sectionKey].description }}
      </p>
      <a href="/{{ sectionKey }}/" class="btn" style="margin-top: var(--space-4); font-size: var(--text-xs);">
        View All →
      </a>
    </div>

    {# Articles in this section #}
    <div class="front-section-strip__articles">
      {% for item in sectionItems %}
      {% set article = item %}
      {% set size = "sm" %}
      {% include "partials/article-card.njk" %}
      {% endfor %}
    </div>

  </section>
  {% endif %}
  {% endfor %}

  {# ─── Quick Sections ──────────────────────────────────────── #}
  <section class="front-quick" aria-label="More sections">
    {% set quickSections = ["arts-culture", "science-technology", "letters"] %}
    {% for sectionKey in quickSections %}
    {% set sectionItems = collections[sectionKey] | limit(3) %}
    <div class="front-quick__col">
      <a href="/{{ sectionKey }}/"
         class="section-badge section-badge--{{ sectionKey }} front-quick__badge">
        {{ sectionKey | replace("-", " ") | title }}
      </a>
      {% for item in sectionItems %}
      <div class="front-quick__item{% if not loop.last %} front-quick__item--border{% endif %}">
        <a href="{{ item.url }}" class="front-quick__link">{{ item.data.title }}</a>
        <time class="front-quick__date">{{ item.date | shortDate }}</time>
      </div>
      {% endfor %}
    </div>
    {% endfor %}
  </section>

  {# ─── Explore section ──────────────────────────────────────── #}
  <section class="front-explore" aria-label="Explore more">
    <p class="front-explore__heading">Beyond the articles</p>
    <div class="front-explore__grid">
      <a href="/library/" class="front-explore__card">
        <strong>Public Domain Library</strong>
        <span>Full texts from the freethought tradition</span>
      </a>
      <a href="/quotes/" class="front-explore__card">
        <strong>Quotes</strong>
        <span>Curated freethought quotes</span>
      </a>
      <a href="/videos/" class="front-explore__card">
        <strong>Videos</strong>
        <span>Lectures, debates, and documentaries</span>
      </a>
      <a href="/timeline/" class="front-explore__card">
        <strong>Timeline</strong>
        <span>2,400 years of freethought history</span>
      </a>
      <a href="/events/" class="front-explore__card">
        <strong>Events</strong>
        <span>Conferences, meetups, and observances</span>
      </a>
      <a href="/glossary/" class="front-explore__card">
        <strong>Glossary</strong>
        <span>Philosophical terms and definitions</span>
      </a>
      <a href="/bookshelf/" class="front-explore__card">
        <strong>Bookshelf</strong>
        <span>Annotated reading recommendations</span>
      </a>
      <a href="/thought-experiments/" class="front-explore__card">
        <strong>Thought Experiments</strong>
        <span>Classic experiments examined</span>
      </a>
      <a href="/trials/" class="front-explore__card">
        <strong>Trials of Thought</strong>
        <span>Landmark trials where ideas were the defendant</span>
      </a>
      <a href="/resources/" class="front-explore__card">
        <strong>Resources</strong>
        <span>Education, legal, support, and tools</span>
      </a>
      <a href="/community/" class="front-explore__card">
        <strong>Community</strong>
        <span>Organizations and groups worldwide</span>
      </a>
      <a href="/games/" class="front-explore__card">
        <strong>Games</strong>
        <span>Trivia, puzzles, and word games</span>
      </a>
      <a href="/newsletter/" class="front-explore__card">
        <strong>Newsletter</strong>
        <span>New articles by email, free</span>
      </a>
      <a href="/search/" class="front-explore__card">
        <strong>Search</strong>
        <span>Find anything on the site</span>
      </a>
      <a href="/support/" class="front-explore__card">
        <strong>Support</strong>
        <span>Help keep us independent</span>
      </a>
    </div>
  </section>

</div>{# /.container #}
