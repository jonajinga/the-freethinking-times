---
layout: layouts/base.njk
---

<div class="container front-page">

  {# ─── Pulse flag: today's date + edition counter ─────────── #}
  <div class="front-pulse" aria-label="Today's edition">
    <span class="front-pulse__date">
      <time datetime="{{ page.date | htmlDateString }}">{{ page.date | readableDate }}</time>
    </span>
    <span class="front-pulse__title">Today on The Freethinking Times</span>
    <span class="front-pulse__count">
      {{ collections.allContent | length }} published &middot;
      {{ collections.glossary | length }} glossary &middot;
      {{ library.works | length }} library
    </span>
  </div>

  {# ─── Lead / Hero ─────────────────────────────────────────── #}
  <section class="front-hero" aria-label="Lead stories">
    {% set leadStory = collections.featured | first or collections.allContent | first %}
    {% if leadStory %}
    {% set article = leadStory %}
    {% set size = "lg" %}
    {% set showImage = true %}
    {% set priority = true %}
    {% include "partials/article-card.njk" %}
    {% set priority = false %}
    {% endif %}
  </section>

  {# ─── Secondary Stories ────────────────────────────────────── #}
  {% set secondaryStories = collections.allContent | limit(4) %}
  {% if secondaryStories.length > 1 %}
  <section class="front-secondary" aria-label="More stories">
    {% for item in secondaryStories %}
    {% if not loop.first %}
    {% set article = item %}
    {% set size = "sm" %}
    {% include "partials/article-card.njk" %}
    {% endif %}
    {% endfor %}
  </section>
  {% endif %}

  {# ─── Section Strips ───────────────────────────────────────── #}
  {% set frontSections = ["opinion", "analysis", "history"] %}
  {% for sectionKey in frontSections %}
  {% set sectionItems = collections[sectionKey] | limit(3) %}
  {% if sectionItems and sectionItems.length > 0 %}
  <section class="front-section-strip" aria-label="{{ sectionKey | title }} section">

    {# Section label column #}
    <div class="front-section-strip__label">
      <a href="/{{ sectionKey }}/"
         class="section-badge section-badge--{{ sectionKey }}"
         style="font-size: var(--text-md); display: block; margin-bottom: var(--space-3);">
        {{ sectionKey | replace("-", " ") | title }}
      </a>
      <p style="font-size: var(--text-sm); color: var(--color-ink-muted); font-style: italic; line-height: var(--leading-normal);">
        {{ site.sections[sectionKey].description }}
      </p>
      <a href="/{{ sectionKey }}/" class="btn" style="margin-top: var(--space-4); font-size: var(--text-xs);"
         aria-label="View all {{ sectionKey | replace('-', ' ') | title }} articles">
        View All →
      </a>
    </div>

    {# Articles in this section #}
    <div class="front-section-strip__articles">
      {% for item in sectionItems %}
      {% set article = item %}
      {% set size = "sm" %}
      {% include "partials/article-card.njk" %}
      {% endfor %}
    </div>

  </section>
  {% endif %}
  {% endfor %}

  {# ─── Cross-project discovery ─────────────────────────────── #}
  <section class="front-projects" aria-label="Explore our projects">
    <header class="front-projects__header">
      <p class="front-projects__kicker">Beyond the page</p>
      <h2 class="front-projects__title">Explore our projects</h2>
    </header>
    <div class="front-projects__grid">
      <a href="/timeline/" class="front-project">
        <span class="front-project__kicker">Interactive</span>
        <span class="front-project__name">Timeline</span>
        <span class="front-project__desc">2,400 years of reason against orthodoxy.</span>
        <span class="front-project__count">{{ timeline | length }} entries</span>
      </a>
      <a href="/library/" class="front-project">
        <span class="front-project__kicker">Primary sources</span>
        <span class="front-project__name">Library</span>
        <span class="front-project__desc">Public-domain texts in a modern reader.</span>
        <span class="front-project__count">{{ library.works | length }} works</span>
      </a>
      <a href="/bookshelf/" class="front-project">
        <span class="front-project__kicker">Recommended</span>
        <span class="front-project__name">Reading list</span>
        <span class="front-project__desc">Books worth serious attention.</span>
        <span class="front-project__count">{{ collections.bookshelf.length }} titles</span>
      </a>
      <a href="/quotes/" class="front-project">
        <span class="front-project__kicker">Curated</span>
        <span class="front-project__name">Quotes</span>
        <span class="front-project__desc">Freethought, pithily stated.</span>
        <span class="front-project__count">{{ quotes | length }} entries</span>
      </a>
      <a href="/glossary/" class="front-project">
        <span class="front-project__kicker">Reference</span>
        <span class="front-project__name">Glossary</span>
        <span class="front-project__desc">The vocabulary we cover, defined precisely.</span>
        <span class="front-project__count">{{ collections.glossary.length }} terms</span>
      </a>
      <a href="/music/" class="front-project">
        <span class="front-project__kicker">Background</span>
        <span class="front-project__name">Music</span>
        <span class="front-project__desc">A soundtrack for thinking.</span>
        <span class="front-project__count">{{ songs | length }} songs</span>
      </a>
    </div>
  </section>

  {# ─── Quick Sections ──────────────────────────────────────── #}
  <section class="front-quick" aria-label="More sections">
    {% set quickSections = ["arts-culture", "science-technology", "letters"] %}
    {% for sectionKey in quickSections %}
    {% set sectionItems = collections[sectionKey] | limit(3) %}
    <div class="front-quick__col">
      <a href="/{{ sectionKey }}/"
         class="section-badge section-badge--{{ sectionKey }} front-quick__badge">
        {{ sectionKey | replace("-", " ") | title }}
      </a>
      {% for item in sectionItems %}
      <div class="front-quick__item{% if not loop.last %} front-quick__item--border{% endif %}">
        <a href="{{ item.url }}" class="front-quick__link">{{ item.data.title }}</a>
        <time class="front-quick__date">{{ item.date | shortDate }}</time>
      </div>
      {% endfor %}
    </div>
    {% endfor %}
  </section>


</div>{# /.container #}
