---
layout: layouts/base.njk
---

<div class="container" style="padding-top: var(--space-10); padding-bottom: var(--space-20);">
  <div class="container--prose" data-pagefind-body>
    <span data-pagefind-filter="section" hidden>Glossary</span>

    <nav style="font-family:var(--font-ui);font-size:var(--text-xs);color:var(--color-ink-faint);margin-bottom:var(--space-6);">
      <a href="/glossary/" style="color:var(--color-link);">Glossary</a> &rarr; {{ title }}
    </nav>

    <h1 style="font-family: var(--font-masthead); font-size: clamp(1.8rem, 5vw, 3rem); margin-bottom: var(--space-4);">{{ title }}</h1>

    <p style="font-family: var(--font-body); font-size: var(--text-lg); color: var(--color-ink-muted); line-height: var(--leading-relaxed); margin-bottom: var(--space-6);">{{ description }}</p>

    {% if etymology %}
    <p style="font-family: var(--font-ui); font-size: var(--text-sm); color: var(--color-ink-faint); margin-bottom: var(--space-6);">
      <strong>Etymology:</strong> {{ etymology }}
    </p>
    {% endif %}

    {% if keyFigures and keyFigures.length %}
    <p style="font-family: var(--font-ui); font-size: var(--text-sm); color: var(--color-ink-faint); margin-bottom: var(--space-6);">
      <strong>Key figures:</strong> {{ keyFigures | join(", ") }}
    </p>
    {% endif %}

    {% if content and content | striptags | trim %}
    <div class="article-body" style="margin-top: var(--space-8); padding-top: var(--space-6); border-top: 1px solid var(--color-rule);">
      {{ content | safe }}
    </div>
    {% endif %}

    {% if relatedTerms and relatedTerms.length %}
    <div style="margin-top: var(--space-8); padding-top: var(--space-6); border-top: 1px solid var(--color-rule);">
      <h2 style="font-family:var(--font-headline);font-size:var(--text-sm);font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--color-ink-faint);margin-bottom:var(--space-3);">Related Terms</h2>
      <ul style="list-style:none;padding:0;display:flex;flex-wrap:wrap;gap:var(--space-2);">
        {% for term in relatedTerms %}
        <li><a href="{{ term.url }}" style="font-family:var(--font-ui);font-size:var(--text-sm);color:var(--color-link);text-decoration:none;padding:var(--space-1) var(--space-3);border:1px solid var(--color-rule);">{{ term.title }}</a></li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}

    <div style="margin-top: var(--space-8);">
      <a href="/glossary/" class="btn">&larr; All Terms</a>
    </div>
  </div>
</div>
