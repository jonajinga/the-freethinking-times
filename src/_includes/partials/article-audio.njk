{#
  article-audio.njk — visible <audio> player when a pre-generated
  Kokoro MP3 exists for this article.

  Lookup uses page.url against the manifest written from sidecar
  JSONs in src/assets/audio/. Articles without a generated MP3
  fall through silently — the toolbar Listen button still works
  via the existing client-side TTS in tts.js.

  preload="none" so the file doesn't download until the reader
  actually presses play (no FCP / LCP cost on article load).
#}
{% set _aud = audioManifest[page.url] %}
{% if _aud %}
{% set _mins = (_aud.duration / 60) | round(0, 'ceil') %}
<figure class="article-audio" data-pagefind-ignore>
  <div class="article-audio__head">
    <span class="article-audio__icon" aria-hidden="true">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M11 5L6 9H2v6h4l5 4V5z"/>
        <path d="M15.54 8.46a5 5 0 0 1 0 7.07"/>
        <path d="M19.07 4.93a10 10 0 0 1 0 14.14"/>
      </svg>
    </span>
    <figcaption class="article-audio__label">
      <span class="article-audio__title">Listen to this article</span>
      <span class="article-audio__meta">{{ _mins }} {{ "minute" if _mins == 1 else "minutes" }}</span>
    </figcaption>
  </div>
  {# Single trigger for the global persistent audio bar — same
     mechanism as every article card on the site. Native <audio>
     controls have been retired here in favour of one consistent
     player surface across the whole publication. #}
  {% set listenUrl = page.url %}
  {% set listenTitle = title %}
  {% set listenSize = "" %}
  {% include "partials/listen-button.njk" %}
</figure>
{% endif %}
