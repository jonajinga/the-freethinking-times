{# Tip CTA buttons.

   - Author button is a disclosure trigger (matches "How We're Funded"
     and "Republish This Story"): click toggles #author-support-panel,
     which is rendered separately by partials/author-support.njk and
     surfaces the author's bio, social links, and tipping options.
   - Publication button (renders only on non-author surfaces; article
     pages set tipHidePublication = true) stays as a direct link with
     a tippy tooltip.

   Set tipAuthor to an author record. Set tipHidePublication = true on
   author-page / article-card surfaces where the publication button
   would be redundant. Precedence per entity: kofi then bmac then
   patreon. #}
{% set authorTipUrl = "" %}
{% if tipAuthor and tipAuthor.tipping %}
  {% set authorTipUrl = tipAuthor.tipping.kofi or tipAuthor.tipping.bmac or tipAuthor.tipping.patreon %}
{% endif %}
{% set pubTipUrl = "" %}
{% if site.tipping %}
  {% set pubTipUrl = site.tipping.kofi or site.tipping.bmac or site.tipping.patreon %}
{% endif %}
{% if authorTipUrl or (pubTipUrl and not tipHidePublication) %}
<div class="tip-buttons">
  {% if authorTipUrl and tipAuthor %}
  <button type="button" class="tip-badge tip-badge--cta" aria-expanded="false" aria-controls="author-support-panel"
          aria-label="Open support details for {{ tipAuthor.name }}"
          data-umami-event="support-learn"
          onclick="toggleArticleDisclosure(this)">Support {{ tipAuthor.name }}</button>
  {% endif %}
  {% if pubTipUrl and not tipHidePublication %}
  <button type="button" class="tip-badge" aria-expanded="false" aria-controls="funding-panel"
          aria-label="How {{ site.title }} is funded"
          data-umami-event="funding-learn"
          onclick="toggleArticleDisclosure(this)">Support {{ site.title }}</button>
  {% endif %}
</div>
{% endif %}
