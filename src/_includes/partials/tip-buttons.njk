{# Tip CTA buttons. Renders up to two buttons (author + publication)
   based on configured tipping URLs. Set tipAuthor to an author record;
   set tipHidePublication = true on author-page/card surfaces where
   the publication button would be redundant. Precedence per entity:
   kofi then bmac then patreon. #}
{% set authorTipUrl = "" %}
{% if tipAuthor and tipAuthor.tipping %}
  {% set authorTipUrl = tipAuthor.tipping.kofi or tipAuthor.tipping.bmac or tipAuthor.tipping.patreon %}
{% endif %}
{% set pubTipUrl = "" %}
{% if site.tipping %}
  {% set pubTipUrl = site.tipping.kofi or site.tipping.bmac or site.tipping.patreon %}
{% endif %}
{% if authorTipUrl or (pubTipUrl and not tipHidePublication) %}
<div class="tip-buttons">
  {% if authorTipUrl %}
  <a class="tip-badge" href="{{ authorTipUrl }}" target="_blank" rel="noopener noreferrer"
     aria-label="Support {{ tipAuthor.name }}"
     data-tippy-content="Support {{ tipAuthor.name }} directly. Your tip goes entirely to the author and helps them continue their independent work."
     data-tippy-theme="badge"
     data-tippy-placement="top">Support {{ tipAuthor.name }}</a>
  {% endif %}
  {% if pubTipUrl and not tipHidePublication %}
  <a class="tip-badge" href="{{ pubTipUrl }}" target="_blank" rel="noopener noreferrer"
     aria-label="Support {{ site.title }}"
     data-tippy-content="Support {{ site.title }}. Reader contributions keep us independent, ad-free, and able to pay our contributors fairly."
     data-tippy-theme="badge"
     data-tippy-placement="top">Support {{ site.title }}</a>
  {% endif %}
</div>
{% endif %}
