<footer class="site-footer" role="contentinfo" data-pagefind-ignore>
  <div class="container">

    {# ── Footer grid ── #}
    <div class="site-footer__grid">

      {# Column 0: Branding — single row: info left, newsletter right #}
      <div class="site-footer__brand">
        <div class="site-footer__brand-info">
          <p style="font-family: var(--font-masthead); font-size: clamp(1rem, 3vw, var(--text-xl)); color: var(--color-ink); margin-bottom: var(--space-2); display: flex; align-items: center; gap: 0.5rem; white-space: nowrap;">
            <img src="/assets/favicon.svg" alt="" aria-hidden="true" width="24" height="24">{{ site.title }}
          </p>
          <p style="font-size: var(--text-sm); color: var(--color-ink-muted); max-width: 42ch; line-height: var(--leading-normal);">
            {{ site.footerByline or ("Founded " + site.founded + ". " + site.tagline) }}
          </p>
          {% if site.tipping %}
          {% set pubTipUrl = site.tipping.kofi or site.tipping.bmac or site.tipping.patreon %}
          {% if pubTipUrl %}
          <div style="margin-top: var(--space-3);">
            <a class="tip-badge tip-badge--pub" href="{{ pubTipUrl }}" target="_blank" rel="noopener noreferrer"
               aria-label="Support {{ site.title }}"
               data-tippy-content="Support {{ site.title }}. Reader contributions keep us independent, ad-free, and able to pay our contributors fairly."
               data-tippy-theme="badge"
               data-tippy-placement="top">
              <span class="tip-badge__label">support</span><span class="tip-badge__value">{{ site.shortTitle or site.title }}</span>
            </a>
          </div>
          {% endif %}
          {% endif %}
        </div>
        <div class="site-footer__brand-newsletter">
          {% set subscribeVariant = "footer" %}
          {% include "partials/subscribe.njk" %}
        </div>
      </div>

      {# Column 1: Sections #}
      <div>
        <p class="site-footer__heading">Sections</p>
        <ul class="site-footer__nav">
          {% for item in nav %}
          {% if item.collection %}
          <li><a href="{{ item.url }}">{{ item.label }}</a></li>
          {% endif %}
          {% endfor %}
        </ul>
      </div>

      {# Columns 2–10: from footerLinks.json (editable via Pages CMS) #}
      {% for col in footerLinks %}
      <div>
        <p class="site-footer__heading">
          {% if col.headingUrl %}<a href="{{ col.headingUrl }}" style="color:inherit;text-decoration:none;">{{ col.heading }}</a>{% else %}{{ col.heading }}{% endif %}
        </p>
        <ul class="site-footer__nav">
          {% for link in col.links %}
          <li><a href="{{ link.url }}"{% if link.title %} title="{{ link.title }}"{% endif %}>{{ link.label }}</a></li>
          {% endfor %}
          {% if col.heading == "Transparency" and site.analytics and site.analytics.dashboardUrl %}
          <li><a href="{{ site.analytics.dashboardUrl }}" target="_blank" rel="noopener noreferrer" title="See the same data we see">Public Analytics</a></li>
          {% endif %}
        </ul>
      </div>
      {% endfor %}

    </div>

    {# ── Bottom bar ── #}
    <div class="site-footer__bottom">
      <p style="font-size: var(--text-xs); color: var(--color-ink-faint);">
        &copy; {{ currentYear }} {{ site.title }}.
        Content is the property of its respective authors.<br>
        Powered by <a href="https://projectbroadsheet.com" target="_blank" rel="noopener noreferrer" style="color: inherit; text-decoration: underline;">Project Broadsheet</a>.
      </p>
    </div>

  </div>{# /.container #}
</footer>
