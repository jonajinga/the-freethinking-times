<footer class="site-footer" role="contentinfo" data-pagefind-ignore>
  <div class="container">

    {# ── Footer grid ── #}
    <div class="site-footer__grid">

      {# Column 0: Branding — single row: info left, newsletter right #}
      <div class="site-footer__brand">
        <div class="site-footer__brand-info">
          <p style="font-family: var(--font-masthead); font-size: clamp(1rem, 3vw, var(--text-xl)); color: var(--color-ink); margin-bottom: var(--space-2); display: flex; align-items: center; gap: 0.5rem; white-space: nowrap;">
            <img src="/assets/favicon.svg" alt="" aria-hidden="true" width="24" height="24">{{ site.title }}
          </p>
          <p style="font-size: var(--text-sm); color: var(--color-ink-muted); max-width: 42ch; line-height: var(--leading-normal);">
            Founded {{ site.founded }}. Investigative. Philosophical. Adversarial to power.
          </p>
        </div>
        <div class="site-footer__brand-newsletter">
          {% set subscribeVariant = "footer" %}
          {% include "partials/subscribe.njk" %}
        </div>
      </div>

      {# Column 1: Sections (editorial only) #}
      <div>
        <p class="site-footer__heading">Sections</p>
        <ul class="site-footer__nav">
          {% for item in site.nav %}
          {% if item.collection %}
          <li><a href="{{ item.url }}">{{ item.label }}</a></li>
          {% endif %}
          {% endfor %}
        </ul>
      </div>

      {# Column 2: Explore #}
      <div>
        <p class="site-footer__heading"><a href="/explore/" style="color:inherit;text-decoration:none;">Explore</a></p>
        <ul class="site-footer__nav">
          <li><a href="/library/">Public Domain Library</a></li>
          <li><a href="/quotes/">Freethought Quotes</a></li>
          <li><a href="/videos/">Freethought Videos</a></li>
          <li><a href="/timeline/">Freethought Timeline</a></li>
          <li><a href="/games/">Games</a></li>
          <li><a href="/resources/">Freethought Resources</a></li>
        </ul>
      </div>

      {# Column 3: Projects #}
      <div>
        <p class="site-footer__heading">Projects</p>
        <ul class="site-footer__nav">
          <li><a href="/glossary/">Freethought Glossary</a></li>
          <li><a href="/bookshelf/">Freethinker's Bookshelf</a></li>
          <li><a href="/thought-experiments/">Thought Experiment Library</a></li>
          <li><a href="/trials/">Trials of Thought</a></li>
          <li><a href="/projects/">All Projects</a></li>
        </ul>
      </div>

      {# Column 4: Community #}
      <div>
        <p class="site-footer__heading">Community</p>
        <ul class="site-footer__nav">
          <li><a href="/community/">Community Hub</a></li>
          <li><a href="/events/">Events Calendar</a></li>
          <li><a href="/community-guidelines/">Community Guidelines</a></li>
          <li><a href="/contribute/">Contribute</a></li>
          <li><a href="/newsletter/">Newsletter</a></li>
          <li><a href="/reader/">RSS Reader</a></li>
        </ul>
      </div>

      {# Column 5: Contact #}
      <div>
        <p class="site-footer__heading">Contact</p>
        <ul class="site-footer__nav">
          <li><a href="/contact/">Contact Us</a></li>
          <li><a href="/feedback/">Feedback</a></li>
          <li><a href="/tips/">Tip Line</a></li>
          <li><a href="/corrections/report/">Corrections</a></li>
          <li><a href="/support/">Support</a></li>
        </ul>
      </div>

      {# Column 6: Submit #}
      <div>
        <p class="site-footer__heading"><a href="/submit/" style="color:inherit;text-decoration:none;">Submit</a></p>
        <ul class="site-footer__nav">
          <li><a href="/submit/">Submit a Piece</a></li>
          <li><a href="/letters/submit/">Write a Letter</a></li>
          <li><a href="/quotes/submit/">Submit Freethought Quote</a></li>
          <li><a href="/events/submit/">Submit Freethought Event</a></li>
          <li><a href="/timeline/submit/">Suggest Timeline Entry</a></li>
          <li><a href="/bookshelf/submit/">Recommend Book</a></li>
          <li><a href="/library/submit/">Suggest Public Domain Text</a></li>
          <li><a href="/glossary/submit/">Suggest Term</a></li>
          <li><a href="/trials/submit/">Suggest Trial</a></li>
          <li><a href="/thought-experiments/submit/">Suggest Thought Experiment</a></li>
        </ul>
      </div>

      {# Column 5: Reader Tools #}
      <div>
        <p class="site-footer__heading"><a href="/reader-tools/" style="color:inherit;text-decoration:none;">Reader Tools</a></p>
        <ul class="site-footer__nav">
          <li><a href="/search/">Search</a></li>
          <li><a href="/start-here/">Start Here</a></li>
          <li><a href="/notes/">Notes & Highlights</a></li>
          <li><a href="/reading-list/">Reading List</a></li>
          <li><a href="/archives/">Archives</a></li>
          <li><a href="/editions/">Editions</a></li>
          <li><a href="/topics/">Topics Index</a></li>
          <li><a href="/your-data/">Your Data</a></li>
          <li><a href="/feed.xml">RSS Feed</a></li>
        </ul>
      </div>

      {# Column 6: About #}
      <div>
        <p class="site-footer__heading">About</p>
        <ul class="site-footer__nav">
          <li><a href="/about/">About Us</a></li>
          <li><a href="/masthead/">Masthead</a></li>
          <li><a href="/ethics/">Editorial Ethics</a></li>
          <li><a href="/editorial/">Editorial Handbook</a></li>
          <li><a href="/contributors/">Contributors</a></li>
          <li><a href="/documents/">Document Library</a></li>
        </ul>
      </div>

      {# Column 7: Transparency #}
      <div>
        <p class="site-footer__heading"><a href="/transparency/" style="color:inherit;text-decoration:none;">Transparency</a></p>
        <ul class="site-footer__nav">
          <li><a href="/features/">Features</a></li>
          <li><a href="/stack/">How It's Built</a></li>
          <li><a href="/changelog/">Changelog</a></li>
          <li><a href="/corrections/">Corrections</a></li>
          <li><a href="/open-source/">Open Source</a></li>
          <li><a href="/style-guide/">Style Guide</a></li>
          {% if site.analytics and site.analytics.dashboardUrl %}<li><a href="{{ site.analytics.dashboardUrl }}" target="_blank" rel="noopener noreferrer">Analytics</a></li>{% endif %}
        </ul>
      </div>

      {# Column 8: Legal #}
      <div>
        <p class="site-footer__heading"><a href="/legal/" style="color:inherit;text-decoration:none;">Legal</a></p>
        <ul class="site-footer__nav">
          <li><a href="/privacy/">Privacy</a></li>
          <li><a href="/terms/">Terms</a></li>
          <li><a href="/cookies/">Cookies</a></li>
          <li><a href="/accessibility/">Accessibility</a></li>
          <li><a href="/site-map/">Site Map</a></li>
        </ul>
      </div>

    </div>

    {# ── Bottom bar ── #}
    <div class="site-footer__bottom">
      <p style="font-size: var(--text-xs); color: var(--color-ink-faint);">
        &copy; {{ currentYear }} {{ site.title }}.
        Content is the property of its respective authors.
      </p>
    </div>

  </div>{# /.container #}
</footer>
