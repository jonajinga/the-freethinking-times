<footer class="site-footer" role="contentinfo" data-pagefind-ignore>
  <div class="container">

    {# ── Subscribe strip ── #}
    <div class="footer-subscribe-strip">

      <div>
        <p style="font-family: var(--font-masthead); font-size: clamp(1rem, 3vw, var(--text-xl)); color: var(--color-ink); margin-bottom: var(--space-2); display: flex; align-items: center; gap: 0.5rem; white-space: nowrap;">
          <img src="/assets/favicon.svg" alt="" aria-hidden="true" width="24" height="24">{{ site.title }}
        </p>
        <p style="font-size: var(--text-sm); color: var(--color-ink-muted); max-width: 42ch; line-height: var(--leading-normal); margin-bottom: var(--space-4);">
          {{ site.description }}
        </p>
        <p style="font-size: var(--text-xs); color: var(--color-ink-faint);">
          Founded {{ site.founded }}. Independent. Accountable to no one but the truth.
        </p>
      </div>

      <div>
        {% set subscribeVariant = "footer" %}
        {% include "partials/subscribe.njk" %}
      </div>

    </div>

    {# ── Footer grid — 3 columns ── #}
    <div class="site-footer__grid">

      {# Sections #}
      <div>
        <p style="font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-ink-faint); margin-bottom: var(--space-3);">Sections</p>
        <ul class="site-footer__nav">
          {% for item in site.nav %}
          <li><a href="{{ item.url }}">{{ item.label }}</a></li>
          {% endfor %}
        </ul>
      </div>

      {# About #}
      <div>
        <p style="font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-ink-faint); margin-bottom: var(--space-3);">About</p>
        <ul class="site-footer__nav">
          <li><a href="/about/">About Us</a></li>
          <li><a href="/newsletter/">Newsletter</a></li>
          <li><a href="/masthead/">Masthead</a></li>
          <li><a href="/ethics/">Editorial Ethics</a></li>
          <li><a href="/editorial/">Editorial Handbook</a></li>
          <li><a href="/features/">Features</a></li>
          <li><a href="/submit/">Submit a Piece</a></li>
          <li><a href="/contributors/">Contributors</a></li>
          <li><a href="/letters/">Letters to the Editor</a></li>
          <li><a href="/documents/">Document Library</a></li>
        </ul>
      </div>

      {# Reader Tools #}
      <div>
        <p style="font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-ink-faint); margin-bottom: var(--space-3);">Reader Tools</p>
        <ul class="site-footer__nav">
          <li><a href="/start-here/">Start Here</a></li>
          <li><a href="/notes/">Notes & Highlights</a></li>
          <li><a href="/reading-list/">Reading List</a></li>
          <li><a href="/editions/">Editions</a></li>
          <li><a href="/archives/">Archives</a></li>
          <li><a href="/quotes/">Quotes</a></li>
          <li><a href="/resources/">Freethought Resources</a></li>
          <li><a href="/videos/">Video Library</a></li>
          <li><a href="/reader/">RSS Reader</a></li>
          <li><a href="/topics/">Topics Index</a></li>
        </ul>
      </div>

      {# Library #}
      <div>
        <p style="font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-ink-faint); margin-bottom: var(--space-3);">Library</p>
        <ul class="site-footer__nav">
          <li><a href="/library/">Library Home</a></li>
          <li><a href="/library/subjects/">Browse by Subject</a></li>
          <li><a href="/library/authors/">Browse by Author</a></li>
        </ul>
        <div style="margin-top: var(--space-4);">
          <a href="/support/" class="btn btn--accent" style="font-size: var(--text-xs);">
            Support Us →
          </a>
        </div>
      </div>

    </div>

    {# ── Bottom bar ── #}
    <div class="site-footer__bottom">
      <p style="font-size: var(--text-xs); color: var(--color-ink-faint);">
        &copy; {{ site.founded }}–{{ currentYear }} {{ site.title }}.
        Content is the property of its respective authors.
      </p>
      <div style="display: flex; gap: var(--space-3); flex-wrap: wrap; justify-content: center;">
        <a href="/privacy/" style="font-size: var(--text-xs); color: var(--color-ink-faint); text-decoration: none;">Privacy</a>
        {% if site.analytics and site.analytics.dashboardUrl %}<a href="{{ site.analytics.dashboardUrl }}" target="_blank" rel="noopener noreferrer" style="font-size: var(--text-xs); color: var(--color-ink-faint); text-decoration: none;">Analytics</a>{% endif %}
        <a href="/corrections/" style="font-size: var(--text-xs); color: var(--color-ink-faint); text-decoration: none;">Corrections</a>
        <a href="/changelog/" style="font-size: var(--text-xs); color: var(--color-ink-faint); text-decoration: none;">Changelog</a>
        <a href="/sitemap.xml" style="font-size: var(--text-xs); color: var(--color-ink-faint); text-decoration: none;">Sitemap</a>
        <a href="/feed.xml" style="font-size: var(--text-xs); color: var(--color-ink-faint); text-decoration: none;">RSS</a>
      </div>
    </div>

  </div>{# /.container #}
</footer>
