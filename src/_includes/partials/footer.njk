<footer class="site-footer" role="contentinfo" data-pagefind-ignore>
  <div class="container">

    {# ── Masthead strip: brand + mission statement + newsletter ── #}
    <div class="site-footer__masthead">
      <div class="site-footer__brand-block">
        <a href="/" class="site-footer__brand-link">
          <img src="/assets/favicon.svg" alt="" aria-hidden="true" width="32" height="32">
          <span class="site-footer__brand-name notranslate">{{ site.title }}</span>
        </a>
        <p class="site-footer__byline">
          {{ site.footerByline or ("Founded " + site.founded + ". " + site.tagline) }}
        </p>

        {# Social / RSS row #}
        <ul class="site-footer__social" aria-label="Follow us">
          {% if site.social.rss %}
          <li><a href="{{ site.social.rss }}" aria-label="RSS feed" title="RSS feed">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
          </a></li>
          {% endif %}
          {% if site.social.twitter %}
          <li><a href="{{ site.social.twitter }}" target="_blank" rel="noopener noreferrer" aria-label="Twitter / X" title="Twitter / X">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a></li>
          {% endif %}
          {% if site.social.mastodon %}
          <li><a href="{{ site.social.mastodon }}" target="_blank" rel="me noopener noreferrer" aria-label="Mastodon" title="Mastodon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.268 5.313c-.35-2.578-2.617-4.61-5.304-5.004C17.51.242 15.792 0 11.813 0h-.03c-3.98 0-4.835.242-5.288.309C3.882.692 1.496 2.518.917 5.127.64 6.412.61 7.837.661 9.143c.074 1.874.088 3.745.26 5.611.118 1.24.325 2.47.62 3.68.55 2.237 2.777 4.098 4.96 4.857 2.336.792 4.849.923 7.256.38.265-.061.527-.132.786-.213.585-.184 1.27-.39 1.774-.753a.057.057 0 0 0 .023-.043v-1.809a.052.052 0 0 0-.02-.041.053.053 0 0 0-.046-.01 20.282 20.282 0 0 1-4.709.545c-2.73 0-3.463-1.284-3.674-1.818a5.593 5.593 0 0 1-.319-1.433.053.053 0 0 1 .066-.054c1.517.363 3.072.546 4.632.546.376 0 .75 0 1.125-.01 1.57-.044 3.224-.124 4.768-.422.038-.008.077-.015.11-.024 2.435-.464 4.753-1.92 4.989-5.604.008-.145.03-1.52.03-1.67.002-.512.167-3.63-.024-5.545zm-3.748 9.195h-2.561V8.29c0-1.309-.55-1.976-1.67-1.976-1.23 0-1.846.79-1.846 2.35v3.403h-2.546V8.663c0-1.56-.617-2.35-1.848-2.35-1.112 0-1.668.668-1.67 1.977v6.218H4.822V8.102c0-1.31.337-2.35 1.011-3.12.696-.77 1.608-1.164 2.74-1.164 1.311 0 2.302.5 2.962 1.498l.638 1.06.638-1.06c.66-.999 1.65-1.498 2.96-1.498 1.13 0 2.043.395 2.74 1.164.675.77 1.012 1.81 1.012 3.12z"/></svg>
          </a></li>
          {% endif %}
          {% if site.social.bluesky %}
          <li><a href="{{ site.social.bluesky }}" target="_blank" rel="noopener noreferrer" aria-label="Bluesky" title="Bluesky">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.911.58-7.386 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 0 1-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.478 0-.69-.139-1.861-.902-2.206-.659-.298-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8Z"/></svg>
          </a></li>
          {% endif %}
          {% if site.social.youtube %}
          <li><a href="{{ site.social.youtube }}" target="_blank" rel="noopener noreferrer" aria-label="YouTube" title="YouTube">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a></li>
          {% endif %}
          <li><a href="/contact/" aria-label="Contact" title="Contact the editors">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </a></li>
        </ul>

        {% if site.tipping %}
        {% set pubTipUrl = site.tipping.kofi or site.tipping.bmac or site.tipping.patreon %}
        {% if pubTipUrl %}
        <div class="site-footer__tip">
          <a class="tip-badge" href="{{ pubTipUrl }}" target="_blank" rel="noopener noreferrer"
             aria-label="Support {{ site.title }}"
             data-tippy-content="Support {{ site.title }}. Reader contributions keep us independent, ad-free, and able to pay our contributors fairly."
             data-tippy-theme="badge"
             data-tippy-placement="top">Support {{ site.title }}</a>
        </div>
        {% endif %}
        {% endif %}
      </div>

      <div class="site-footer__newsletter">
        <p class="site-footer__heading">Newsletter</p>
        <p class="site-footer__newsletter-blurb">One email, occasionally. No tracking, no selling your address, one-click unsubscribe.</p>
        {% set subscribeVariant = "footer" %}
        {% include "partials/subscribe.njk" %}
      </div>
    </div>

    {# ── Link columns ── #}
    <div class="site-footer__grid">

      {# Sections #}
      <div class="site-footer__col">
        <p class="site-footer__heading">
          <a href="/archives/">Sections</a>
        </p>
        <ul class="site-footer__nav">
          {% for item in nav %}
          {% if item.collection %}
          <li><a href="{{ item.url }}">{{ item.label }}</a></li>
          {% endif %}
          {% endfor %}
        </ul>
      </div>

      {# Columns from footerLinks.json #}
      {% for col in footerLinks %}
      <div class="site-footer__col">
        <p class="site-footer__heading">
          {% if col.headingUrl %}<a href="{{ col.headingUrl }}">{{ col.heading }}</a>{% else %}{{ col.heading }}{% endif %}
        </p>
        <ul class="site-footer__nav">
          {% for link in col.links %}
          <li><a href="{{ link.url }}"{% if link.title %} data-tippy-content="{{ link.title }}"{% endif %}>{{ link.label }}</a></li>
          {% endfor %}
          {% if col.heading == "Transparency" and site.analytics and site.analytics.dashboardUrl %}
          <li><a href="{{ site.analytics.dashboardUrl }}" target="_blank" rel="noopener noreferrer" data-tippy-content="Our public analytics dashboard, the same numbers we see, open for readers to inspect. No individual tracking, just aggregate pageviews, referrers, and country.">Public Analytics</a></li>
          {% endif %}
        </ul>
      </div>
      {% endfor %}

    </div>

    {# ── Bottom bar ── #}
    <div class="site-footer__bottom">
      <p class="site-footer__copyright">
        &copy; {{ currentYear }} {{ site.title }}. Content is the property of its respective authors.
      </p>
      <p class="site-footer__powered">
        Powered by <a href="https://projectbroadsheet.com" target="_blank" rel="noopener noreferrer">Project Broadsheet</a>
      </p>
      {# Visible IndieWeb rel=me anchors. Machine-readable copies live in
         <head> via base.njk; the visible anchors here are the canonical
         indieweb convention and serve as a fallback if the head link is
         ever stripped by a reader-mode tool. #}
      {% if site.indieweb and site.indieweb.me and site.indieweb.me.length %}
      <p class="site-footer__identity" aria-label="IndieWeb identities">
        {% for me in site.indieweb.me %}
        <a rel="me" href="{{ me }}">{{ me | replace("https://", "") | replace("http://", "") }}</a>{% if not loop.last %} &middot; {% endif %}
        {% endfor %}
      </p>
      {% endif %}
    </div>

  </div>{# /.container #}
</footer>
