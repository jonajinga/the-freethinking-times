---
layout: base
title: Freethought Music
description: Curated playlists for reading, thinking, and reflecting — music connected to the freethought tradition.
permalink: /music/
---

<div class="container" style="padding-top: var(--space-10); padding-bottom: var(--space-20);">
  <div class="container--prose">

    <header style="padding-bottom: var(--space-6); border-bottom: 3px solid var(--color-ink); margin-bottom: var(--space-8);">
      <a href="/projects/" style="font-family:var(--font-ui);font-size:var(--text-xs);color:var(--color-ink-faint);text-decoration:none;">&larr; Projects</a>
      <h1 style="font-family: var(--font-masthead); font-size: clamp(1.8rem, 5vw, 3.815rem); margin-bottom: var(--space-4); margin-top: var(--space-2);">Freethought Music</h1>
      <p style="color: var(--color-ink-muted); font-size: var(--text-md); font-style: italic; max-width: 45ch;">
        Curated playlists for reading, thinking, and reflecting.
      </p>
      <p style="font-family: var(--font-ui); font-size: var(--text-sm); margin-top: var(--space-4);">
        Know a song we should add? <a href="/music/submit/" style="color: var(--color-link); font-weight: 600;">Suggest it</a>
      </p>
    </header>

    {# Search, filter, and custom URL — single row #}
    <div class="music-toolbar">
      <input type="search" id="music-search" placeholder="Search playlists..." aria-label="Search playlists" class="music-toolbar__search">
      <select id="music-category" aria-label="Filter by category" class="music-toolbar__select">
        <option value="">All categories</option>
        {% set cats = [] %}
        {% for pl in playlists %}{% if pl.category and pl.category not in cats %}{% set cats = cats.concat([pl.category]) %}{% endif %}{% endfor %}
        {% for cat in cats %}<option value="{{ cat }}">{{ cat }}</option>{% endfor %}
      </select>
      <div class="music-toolbar__custom">
        <input type="url" id="custom-playlist-url" placeholder="Paste playlist URL..." aria-label="YouTube playlist URL" class="music-toolbar__url">
        <button type="button" class="music-toolbar__play-btn" id="custom-play-btn">Play URL</button>
      </div>
    </div>

    {# Playlist cards #}
    <div class="music-grid" id="music-grid">
      {% for pl in playlists %}
      <div class="music-card" data-playlist-id="{{ pl.playlistId }}" data-name="{{ pl.name | lower }}" data-desc="{{ pl.description | lower }}" data-category="{{ pl.category }}">
        <div class="music-card__header">
          <span class="music-card__category">{{ pl.category }}</span>
          <h2 class="music-card__title">{{ pl.name }}</h2>
          <p class="music-card__desc">{{ pl.description }}</p>
        </div>
        <div class="music-card__actions">
          <button type="button" class="btn" onclick="window.musicPlayer.loadPlaylist('{{ pl.playlistId }}','{{ pl.name | escape }}')">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="margin-right:4px;vertical-align:-2px;"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            Play
          </button>
          <button type="button" class="music-card__toggle" onclick="this.parentElement.parentElement.querySelector('.music-card__tracklist').hidden=!this.parentElement.parentElement.querySelector('.music-card__tracklist').hidden;this.textContent=this.parentElement.parentElement.querySelector('.music-card__tracklist').hidden?'Show tracks':'Hide tracks';">Show tracks</button>
        </div>
        <div class="music-card__tracklist" hidden>
          <p style="font-family:var(--font-ui);font-size:var(--text-xs);color:var(--color-ink-faint);font-style:italic;padding:var(--space-3);">Click Play to load track list</p>
        </div>
      </div>
      {% endfor %}
    </div>

    <p id="music-no-results" hidden style="font-family:var(--font-ui);font-size:var(--text-sm);color:var(--color-ink-faint);font-style:italic;text-align:center;padding:var(--space-6) 0;">No playlists match your search.</p>

  </div>
</div>

{# YouTube API + player container #}
<script src="https://www.youtube.com/iframe_api"></script>
<div id="yt-player-wrap" style="position:fixed;bottom:60px;left:0;width:1px;height:1px;overflow:hidden;pointer-events:none;z-index:-1;">
  <div id="arena-dj-player"></div>
</div>

{# Sticky player bar at bottom #}
<div id="music-player" class="music-player" hidden>
  <div class="music-player__info">
    <span class="music-player__playlist-name" id="mp-playlist-name"></span>
    <span class="music-player__now-playing" id="mp-now-playing">Loading...</span>
  </div>
  <div class="music-player__controls">
    <button type="button" id="mp-prev" aria-label="Previous" class="music-player__btn">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="19 20 9 12 19 4 19 20"/><line x1="5" y1="19" x2="5" y2="5" stroke="currentColor" stroke-width="2"/></svg>
    </button>
    <button type="button" id="mp-play" aria-label="Play/Pause" class="music-player__btn music-player__btn--play">
      <svg id="mp-play-icon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
      <svg id="mp-pause-icon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="display:none"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
    </button>
    <button type="button" id="mp-next" aria-label="Next" class="music-player__btn">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 4 15 12 5 20 5 4"/><line x1="19" y1="5" x2="19" y2="19" stroke="currentColor" stroke-width="2"/></svg>
    </button>
    <input type="range" id="mp-volume" min="0" max="100" value="80" aria-label="Volume" class="music-player__volume">
  </div>
</div>

<style>
/* Toolbar */
.music-toolbar {
  display: flex;
  gap: var(--space-3);
  margin-bottom: var(--space-8);
  flex-wrap: wrap;
  align-items: center;
}

.music-toolbar__search {
  flex: 1;
  min-width: 160px;
  font-family: var(--font-ui);
  font-size: var(--text-sm);
  padding: var(--space-2) var(--space-4);
  border: 1px solid var(--color-rule);
  background: var(--color-bg);
  color: var(--color-ink);
}

.music-toolbar__select {
  font-family: var(--font-ui);
  font-size: var(--text-sm);
  padding: var(--space-2) var(--space-3);
  border: 1px solid var(--color-rule);
  background: var(--color-bg);
  color: var(--color-ink);
}

.music-toolbar__custom {
  display: flex;
  gap: var(--space-2);
}

.music-toolbar__url {
  width: 200px;
  font-family: var(--font-ui);
  font-size: var(--text-xs);
  padding: var(--space-2) var(--space-3);
  border: 1px solid var(--color-rule);
  background: var(--color-bg);
  color: var(--color-ink);
}

.music-toolbar__play-btn {
  font-family: var(--font-ui);
  font-size: var(--text-xs);
  font-weight: 600;
  padding: var(--space-2) var(--space-3);
  border: 1px solid var(--color-ink);
  background: var(--color-bg);
  color: var(--color-ink);
  cursor: pointer;
  white-space: nowrap;
  transition: background 0.2s, color 0.2s;
}

.music-toolbar__play-btn:hover {
  background: var(--color-ink);
  color: var(--color-bg);
}

@media (max-width: 640px) {
  .music-toolbar__custom { width: 100%; }
  .music-toolbar__url { flex: 1; }
}

/* Player bar — fixed at bottom */
.music-player {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-4);
  padding: var(--space-3) var(--space-6);
  background: var(--color-ink);
  color: var(--color-bg);
  z-index: var(--z-overlay);
  box-shadow: 0 -2px 12px rgba(0,0,0,0.2);
}

.music-player[hidden] { display: none !important; }

.music-player__info { flex: 1; min-width: 0; }

.music-player__playlist-name {
  font-family: var(--font-ui);
  font-size: var(--text-xs);
  opacity: 0.5;
  display: block;
}

.music-player__now-playing {
  font-family: var(--font-ui);
  font-size: var(--text-sm);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  display: block;
}

.music-player__controls {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  flex-shrink: 0;
}

.music-player__btn {
  background: none;
  border: none;
  color: inherit;
  cursor: pointer;
  padding: var(--space-1);
  display: flex;
  align-items: center;
  opacity: 0.8;
  transition: opacity 0.15s;
}

.music-player__btn:hover { opacity: 1; }
.music-player__btn--play { opacity: 1; }

.music-player__volume { width: 80px; accent-color: var(--color-accent); }

/* Playlist cards */
.music-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: var(--space-6);
}

.music-card {
  border: 1px solid var(--color-rule);
  border-top: 3px solid var(--color-accent);
  background: var(--color-bg);
  transition: box-shadow 0.2s;
}

.music-card:hover { box-shadow: 0 2px 8px rgba(0,0,0,0.06); }

.music-card__header { padding: var(--space-5) var(--space-6); }

.music-card__category {
  font-family: var(--font-ui);
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--color-accent);
}

.music-card__title {
  font-family: var(--font-headline);
  font-size: var(--text-md);
  font-weight: 700;
  margin: var(--space-2) 0 var(--space-3);
}

.music-card__desc {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  color: var(--color-ink-muted);
  line-height: 1.5;
  margin: 0;
}

.music-card__actions {
  padding: 0 var(--space-6) var(--space-5);
  display: flex;
  gap: var(--space-3);
  align-items: center;
}

.music-card__toggle {
  font-family: var(--font-ui);
  font-size: var(--text-xs);
  color: var(--color-link);
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
}

.music-card__toggle:hover { text-decoration: underline; }

.music-card__tracklist {
  border-top: 1px solid var(--color-rule);
  max-height: 250px;
  overflow-y: auto;
}

.music-card__tracklist[hidden] { display: none; }

.music-track {
  display: flex;
  gap: var(--space-2);
  padding: var(--space-2) var(--space-6);
  font-family: var(--font-ui);
  font-size: var(--text-xs);
  color: var(--color-ink-muted);
  border-bottom: 1px solid var(--color-rule);
  cursor: pointer;
  transition: background 0.15s;
}

.music-track:last-child { border-bottom: none; }
.music-track:hover { background: var(--color-bg-alt); }

.music-track__num { color: var(--color-ink-faint); min-width: 1.5em; }

@media (max-width: 640px) {
  .music-player { flex-direction: column; gap: var(--space-2); padding: var(--space-2) var(--space-4); }
  .music-player__volume { width: 100%; }
}
</style>

<script>
(function () {
  var player = null;
  var ready = false;
  var currentName = '';
  var activeCard = null;
  var targetVolume = 80;

  var playerBar = document.getElementById('music-player');
  var playlistNameEl = document.getElementById('mp-playlist-name');
  var nowPlayingEl = document.getElementById('mp-now-playing');
  var playIcon = document.getElementById('mp-play-icon');
  var pauseIcon = document.getElementById('mp-pause-icon');
  var volumeSlider = document.getElementById('mp-volume');

  function extractId(raw) {
    if (!raw) return '';
    var m = raw.match(/[?&]list=([a-zA-Z0-9_-]+)/);
    if (m) return m[1];
    m = raw.match(/^(PL[a-zA-Z0-9_-]{10,}|OLAK[a-zA-Z0-9_-]+|RDCLAK[a-zA-Z0-9_-]+)/);
    return m ? m[1] : raw;
  }

  // YouTube API ready callback
  window.onYouTubeIframeAPIReady = function () {
    ready = true;
  };

  function createPlayer(playlistId, cb) {
    var containerId = 'arena-dj-player';
    var old = document.getElementById(containerId);
    if (old && player && player.destroy) {
      try { player.destroy(); } catch (e) {}
    }
    // Recreate container
    var wrap = document.getElementById('yt-player-wrap');
    wrap.innerHTML = '<div id="' + containerId + '"></div>';

    var plId = extractId(playlistId);
    var vars = {
      autoplay: 1,
      controls: 0,
      disablekb: 1,
      fs: 0,
      modestbranding: 1,
      rel: 0,
      playsinline: 1,
      mute: 1
    };
    if (plId) {
      vars.list = plId;
      vars.listType = 'playlist';
    }

    player = new YT.Player(containerId, {
      height: '1',
      width: '1',
      playerVars: vars,
      events: {
        onReady: function () {
          ready = true;
          // Start muted, then unmute and set volume
          player.setVolume(0);
          player.unMute();
          fadeIn();
          if (cb) cb();
          setTimeout(updateNowPlaying, 1500);
        },
        onStateChange: function (e) {
          if (e.data === YT.PlayerState.PLAYING) {
            playIcon.style.display = 'none';
            pauseIcon.style.display = '';
          } else {
            playIcon.style.display = '';
            pauseIcon.style.display = 'none';
          }
          updateNowPlaying();
        },
        onError: function () {
          nowPlayingEl.textContent = 'Playlist not found — try a different URL';
        }
      }
    });
  }

  function fadeIn() {
    if (!player) return;
    var vol = 0;
    targetVolume = parseInt(volumeSlider.value, 10) || 80;
    var step = targetVolume / 20;
    var iv = setInterval(function () {
      vol += step;
      if (vol >= targetVolume) { vol = targetVolume; clearInterval(iv); }
      if (player && player.setVolume) player.setVolume(Math.round(vol));
    }, 50);
  }

  function updateNowPlaying() {
    if (!player || !player.getVideoData) return;
    var d = player.getVideoData();
    nowPlayingEl.textContent = d.title || 'Loading...';
    playlistNameEl.textContent = currentName;
  }

  function loadTracklist() {
    if (!player || !player.getPlaylist || !activeCard) return;
    var ids = player.getPlaylist();
    if (!ids || !ids.length) {
      setTimeout(loadTracklist, 1500);
      return;
    }
    var tl = activeCard.querySelector('.music-card__tracklist');
    if (!tl) return;
    tl.innerHTML = '';
    tl.hidden = false;
    var toggle = activeCard.querySelector('.music-card__toggle');
    if (toggle) toggle.textContent = 'Hide tracks';

    ids.forEach(function (id, i) {
      var row = document.createElement('div');
      row.className = 'music-track';
      row.innerHTML = '<span class="music-track__num">' + (i + 1) + '</span><span>Loading...</span>';
      row.addEventListener('click', function () { if (player) player.playVideoAt(i); });
      tl.appendChild(row);
      // Fetch title
      fetch('https://noembed.com/embed?url=https://www.youtube.com/watch?v=' + id)
        .then(function (r) { return r.json(); })
        .then(function (d) { if (d.title) row.querySelector('span:last-child').textContent = d.title; })
        .catch(function () { row.querySelector('span:last-child').textContent = 'Track ' + (i + 1); });
    });
  }

  setInterval(function () { if (player && ytReady) updateNowPlaying(); }, 3000);

  window.musicPlayer = {
    loadPlaylist: function (id, name) {
      currentName = name;
      playerBar.hidden = false;
      playlistNameEl.textContent = name;
      nowPlayingEl.textContent = 'Loading...';

      // Mark active card
      document.querySelectorAll('.music-card').forEach(function (c) { c.style.borderTopColor = ''; });
      activeCard = document.querySelector('[data-playlist-id="' + id + '"]');
      if (activeCard) activeCard.style.borderTopColor = 'var(--color-link)';

      if (ready) {
        createPlayer(id, function () { setTimeout(loadTracklist, 2000); });
      } else {
        // Wait for API
        var wait = setInterval(function () {
          if (ready || (window.YT && window.YT.Player)) {
            clearInterval(wait);
            ready = true;
            createPlayer(id, function () { setTimeout(loadTracklist, 2000); });
          }
        }, 200);
      }
    }
  };

  // Transport controls
  document.getElementById('mp-play').addEventListener('click', function () {
    if (!player) return;
    var s = player.getPlayerState();
    if (s === YT.PlayerState.PLAYING) player.pauseVideo();
    else player.playVideo();
  });

  document.getElementById('mp-next').addEventListener('click', function () {
    if (player) { player.nextVideo(); setTimeout(updateNowPlaying, 500); }
  });

  document.getElementById('mp-prev').addEventListener('click', function () {
    if (player) { player.previousVideo(); setTimeout(updateNowPlaying, 500); }
  });

  volumeSlider.addEventListener('input', function () {
    if (player) player.setVolume(parseInt(this.value, 10));
  });

  // Custom playlist URL
  document.getElementById('custom-play-btn').addEventListener('click', function () {
    var url = document.getElementById('custom-playlist-url').value.trim();
    if (!url) return;
    var id = extractId(url);
    if (id) {
      window.musicPlayer.loadPlaylist(id, 'Custom Playlist');
    } else {
      alert('Paste a YouTube playlist URL like:\nhttps://www.youtube.com/playlist?list=PLxxx');
    }
  });

  document.getElementById('custom-playlist-url').addEventListener('keydown', function (e) {
    if (e.key === 'Enter') document.getElementById('custom-play-btn').click();
  });

  // Search and filter
  var searchInput = document.getElementById('music-search');
  var catFilter = document.getElementById('music-category');
  var cards = document.querySelectorAll('.music-card');
  var noResults = document.getElementById('music-no-results');

  function filterMusic() {
    var q = (searchInput.value || '').toLowerCase().trim();
    var cat = catFilter.value;
    var visible = 0;
    cards.forEach(function (card) {
      var show = true;
      if (q && card.dataset.name.indexOf(q) === -1 && card.dataset.desc.indexOf(q) === -1) show = false;
      if (cat && card.dataset.category !== cat) show = false;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    noResults.hidden = visible > 0;
  }

  if (searchInput) searchInput.addEventListener('input', filterMusic);
  if (catFilter) catFilter.addEventListener('change', filterMusic);
})();
</script>
