---
layout: base
title: Freethought Music
description: Songs and playlists connected to the freethought tradition — music that questions, challenges, and celebrates the examined life.
permalink: /music/
---

<div class="container" style="padding-top: var(--space-10); padding-bottom: var(--space-20);">

  <header style="padding-bottom: var(--space-6); border-bottom: 3px solid var(--color-ink); margin-bottom: var(--space-8); text-align: center;">
    <a href="/projects/" style="font-family:var(--font-ui);font-size:var(--text-xs);color:var(--color-ink-faint);text-decoration:none;">&larr; Projects</a>
    <h1 style="font-family: var(--font-masthead); font-size: clamp(1.8rem, 5vw, 3.815rem); margin-bottom: var(--space-4); margin-top: var(--space-2);">Freethought Music</h1>
    <p style="color: var(--color-ink-muted); font-size: var(--text-md); font-style: italic; max-width: 50ch; margin-inline: auto;">
      Songs that question, challenge, and celebrate the examined life. Playlists for reading, thinking, and reflecting.
    </p>
    <div style="display:flex;justify-content:center;margin-top:var(--space-4);">
      <p style="font-family: var(--font-ui); font-size: var(--text-sm); margin: 0;">
        Know a song we should add? <a href="/music/submit/" style="color: var(--color-link); font-weight: 600;">Suggest it</a>
      </p>
    </div>
  </header>

  {# ── Song Collection ── #}
  <section style="margin-bottom: var(--space-16);">
    <h2 style="font-family: var(--font-headline); font-size: var(--text-xl); margin-bottom: var(--space-2);">Song Collection</h2>
    <p style="font-family: var(--font-body); font-size: var(--text-sm); color: var(--color-ink-muted); margin-bottom: var(--space-6); max-width: 55ch;">
      Songs with lyrics that reflect freethought, humanist, and rationalist ideas — from questioning faith to celebrating reason and human dignity.
    </p>

    {# Search & filter #}
    <div style="display:flex;gap:var(--space-3);margin-bottom:var(--space-6);flex-wrap:wrap;">
      <input type="search" id="song-search" placeholder="Search songs..." aria-label="Search songs" style="flex:1;min-width:180px;font-family:var(--font-ui);font-size:var(--text-sm);padding:var(--space-2) var(--space-4);border:1px solid var(--color-rule);background:var(--color-bg);color:var(--color-ink);">
      <select id="song-genre" aria-label="Genre" style="font-family:var(--font-ui);font-size:var(--text-sm);padding:var(--space-2) var(--space-3);border:1px solid var(--color-rule);background:var(--color-bg);color:var(--color-ink);">
        <option value="">All genres</option>
        {% set genres = [] %}
        {% for s in songs %}{% if s.genre and s.genre not in genres %}{% set genres = genres.concat([s.genre]) %}{% endif %}{% endfor %}
        {% for g in genres | sort %}<option>{{ g }}</option>{% endfor %}
      </select>
      <select id="song-tag" aria-label="Tag" style="font-family:var(--font-ui);font-size:var(--text-sm);padding:var(--space-2) var(--space-3);border:1px solid var(--color-rule);background:var(--color-bg);color:var(--color-ink);">
        <option value="">All tags</option>
        {% set allTags = [] %}
        {% for s in songs %}{% for t in s.tags %}{% if t not in allTags %}{% set allTags = allTags.concat([t]) %}{% endif %}{% endfor %}{% endfor %}
        {% for t in allTags | sort %}<option>{{ t }}</option>{% endfor %}
      </select>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:var(--space-4);" id="song-grid">
      {% for s in songs | sort(false, false, 'artist') %}
      <div class="song-card" data-search="{{ s.title | lower }} {{ s.artist | lower }} {{ s.album | lower }}" data-genre="{{ s.genre }}" data-tags="{{ s.tags | join(',') }}">
        <div style="flex:1;padding:var(--space-4) var(--space-6);">
          <span style="font-family:var(--font-ui);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--color-accent);">{{ s.genre }}</span>
          <h3 style="font-family:var(--font-headline);font-size:var(--text-base);font-weight:700;margin:var(--space-1) 0 var(--space-1);line-height:var(--leading-snug);">{{ s.title }}</h3>
          <p style="font-family:var(--font-ui);font-size:var(--text-sm);color:var(--color-ink-muted);margin:0;">{{ s.artist }}{% if s.album %} &middot; <em>{{ s.album }}</em>{% endif %}{% if s.year %} ({{ s.year }}){% endif %}</p>
          {% if s.tags.length %}
          <div style="display:flex;flex-wrap:wrap;gap:var(--space-1);margin-top:var(--space-2);">
            {% for t in s.tags %}<span style="font-family:var(--font-ui);font-size:9px;text-transform:uppercase;letter-spacing:0.06em;color:var(--color-ink-faint);border:1px solid var(--color-rule);padding:1px var(--space-2);">{{ t }}</span>{% endfor %}
          </div>
          {% endif %}
        </div>
        {% if s.url %}
        <div style="padding:var(--space-3) var(--space-6);border-top:1px solid var(--color-rule);">
          <a href="{{ s.url }}" target="_blank" rel="noopener" style="font-family:var(--font-ui);font-size:var(--text-xs);color:var(--color-link);text-decoration:none;">Listen on YouTube &nearr;</a>
        </div>
        {% endif %}
      </div>
      {% endfor %}
    </div>

    <p id="song-empty" hidden style="font-family:var(--font-ui);font-size:var(--text-sm);color:var(--color-ink-faint);font-style:italic;text-align:center;padding:var(--space-8) 0;">No songs match your search.</p>

    <p style="font-family:var(--font-ui);font-size:var(--text-sm);color:var(--color-ink-faint);margin-top:var(--space-6);text-align:center;">
      {{ songs | length }} songs in the collection
    </p>
  </section>

  {# ── Playlists ── #}
  <section>
    <h2 style="font-family: var(--font-headline); font-size: var(--text-xl); margin-bottom: var(--space-2);">Playlists</h2>
    <p style="font-family: var(--font-body); font-size: var(--text-sm); color: var(--color-ink-muted); margin-bottom: var(--space-6); max-width: 55ch;">
      Background playlists that play across the site as you browse. Click play and keep reading.
    </p>

    {# Play your own #}
    <div style="padding:var(--space-4) var(--space-5);border:1px solid var(--color-rule);background:var(--color-bg-alt);margin-bottom:var(--space-6);">
      <label style="font-family:var(--font-ui);font-size:var(--text-xs);font-weight:600;color:var(--color-ink-faint);text-transform:uppercase;letter-spacing:0.08em;">Play your own playlist</label>
      <div style="display:flex;gap:var(--space-2);margin-top:var(--space-2);">
        <input type="url" id="custom-url" placeholder="Paste a YouTube Music playlist or channel URL..." style="flex:1;font-family:var(--font-ui);font-size:var(--text-sm);padding:var(--space-2) var(--space-4);border:1px solid var(--color-rule);background:var(--color-bg);color:var(--color-ink);">
        <button type="button" class="btn" id="custom-play">Play</button>
      </div>
    </div>

    {# Playlist search & filter #}
    <div style="display:flex;gap:var(--space-3);margin-bottom:var(--space-6);flex-wrap:wrap;">
      <input type="search" id="music-search" placeholder="Search playlists..." aria-label="Search playlists" style="flex:1;min-width:180px;font-family:var(--font-ui);font-size:var(--text-sm);padding:var(--space-2) var(--space-4);border:1px solid var(--color-rule);background:var(--color-bg);color:var(--color-ink);">
      <select id="music-cat" aria-label="Category" style="font-family:var(--font-ui);font-size:var(--text-sm);padding:var(--space-2) var(--space-3);border:1px solid var(--color-rule);background:var(--color-bg);color:var(--color-ink);">
        <option value="">All categories</option>
        {% set cats = [] %}
        {% for pl in playlists %}{% if pl.category and pl.category not in cats %}{% set cats = cats.concat([pl.category]) %}{% endif %}{% endfor %}
        {% for cat in cats %}<option>{{ cat }}</option>{% endfor %}
      </select>
    </div>

    {# Playlist cards #}
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:var(--space-6);" id="music-grid">
      {% for pl in playlists %}
      <div class="music-card" data-search="{{ pl.name | lower }} {{ pl.description | lower }}" data-cat="{{ pl.category }}">
        <div style="padding:var(--space-6) var(--space-8);flex:1;">
          <span style="font-family:var(--font-ui);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--color-accent);">{{ pl.category }}</span>
          <h3 style="font-family:var(--font-headline);font-size:var(--text-md);font-weight:700;margin:var(--space-2) 0 var(--space-3);line-height:1.3;">{{ pl.name }}</h3>
          <p style="font-family:var(--font-body);font-size:var(--text-sm);color:var(--color-ink-muted);line-height:1.6;margin:0;">{{ pl.description }}</p>
        </div>
        <div style="padding:var(--space-4) var(--space-8);border-top:1px solid var(--color-rule);display:flex;align-items:center;gap:var(--space-4);">
          <button type="button" class="btn" onclick="window.musicPlayer.loadPlaylist('{{ pl.playlistId }}','{{ pl.name | escape }}')">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" style="margin-right:4px;"><polygon points="5 3 19 12 5 21"/></svg>
            Play
          </button>
          <a href="https://music.youtube.com/playlist?list={{ pl.playlistId }}" target="_blank" rel="noopener" style="font-family:var(--font-ui);font-size:var(--text-xs);color:var(--color-link);">Open in YouTube Music &nearr;</a>
        </div>
      </div>
      {% endfor %}
    </div>

    <p id="music-empty" hidden style="font-family:var(--font-ui);font-size:var(--text-sm);color:var(--color-ink-faint);font-style:italic;text-align:center;padding:var(--space-8) 0;">No playlists match your search.</p>
  </section>

</div>

<style>
.song-card {
  border: 1px solid var(--color-rule);
  border-left: 3px solid var(--color-accent);
  background: var(--color-bg);
  display: flex;
  flex-direction: column;
  transition: box-shadow 0.2s;
}
.song-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.06); }

.music-card {
  border: 1px solid var(--color-rule);
  border-top: 3px solid var(--color-accent);
  background: var(--color-bg);
  display: flex;
  flex-direction: column;
  transition: box-shadow 0.2s;
}
.music-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.06); }
</style>

<script>
(function () {
  // Custom URL
  document.getElementById('custom-play').addEventListener('click', function () {
    var url = document.getElementById('custom-url').value.trim();
    if (!url) return;
    var id = null;
    var m = url.match(/[?&]list=([a-zA-Z0-9_-]+)/);
    if (m) id = m[1];
    if (!id) { m = url.match(/\/channel\/(UC[a-zA-Z0-9_-]+)/); if (m) id = 'UU' + m[1].substring(2); }
    if (!id) { m = url.match(/(PL[a-zA-Z0-9_-]{10,}|OLAK[a-zA-Z0-9_-]+|RDCLAK[a-zA-Z0-9_-]+)/); if (m) id = m[1]; }
    if (id) window.musicPlayer.loadPlaylist(id, 'Custom Playlist');
    else alert('Paste a YouTube Music playlist or channel URL');
  });

  document.getElementById('custom-url').addEventListener('keydown', function (e) {
    if (e.key === 'Enter') document.getElementById('custom-play').click();
  });

  // Song filtering
  var songSearch = document.getElementById('song-search');
  var songGenre = document.getElementById('song-genre');
  var songTag = document.getElementById('song-tag');
  var songCards = document.querySelectorAll('.song-card');
  var songEmpty = document.getElementById('song-empty');

  function filterSongs() {
    var q = (songSearch.value || '').toLowerCase().trim();
    var g = songGenre.value;
    var t = songTag.value;
    var n = 0;
    songCards.forEach(function (card) {
      var matchQ = !q || card.dataset.search.indexOf(q) !== -1;
      var matchG = !g || card.dataset.genre === g;
      var matchT = !t || card.dataset.tags.indexOf(t) !== -1;
      var show = matchQ && matchG && matchT;
      card.style.display = show ? '' : 'none';
      if (show) n++;
    });
    songEmpty.hidden = n > 0;
  }

  songSearch.addEventListener('input', filterSongs);
  songGenre.addEventListener('change', filterSongs);
  songTag.addEventListener('change', filterSongs);

  // Playlist filtering
  var search = document.getElementById('music-search');
  var cat = document.getElementById('music-cat');
  var cards = document.querySelectorAll('.music-card');
  var empty = document.getElementById('music-empty');

  function filterPlaylists() {
    var q = (search.value || '').toLowerCase().trim();
    var c = cat.value;
    var n = 0;
    cards.forEach(function (card) {
      var show = (!q || card.dataset.search.indexOf(q) !== -1) && (!c || card.dataset.cat === c);
      card.style.display = show ? '' : 'none';
      if (show) n++;
    });
    empty.hidden = n > 0;
  }

  search.addEventListener('input', filterPlaylists);
  cat.addEventListener('change', filterPlaylists);
})();
</script>
