---
layout: base
title: The Freethought Glossary
description: An A-Z glossary of terms essential to freethought, secularism, and rational inquiry — defined clearly and concisely.
permalink: /glossary/
---

<div class="container" style="padding-top: var(--space-10); padding-bottom: var(--space-20);">

  <header style="padding-bottom: var(--space-6); border-bottom: 3px solid var(--color-ink); margin-bottom: var(--space-8); text-align: center;">
    <h1 style="font-family: var(--font-masthead); font-size: clamp(1.8rem, 5vw, 3.815rem); margin-bottom: var(--space-4);">The Freethought Glossary</h1>
    <p style="color: var(--color-ink-muted); font-size: var(--text-md); font-style: italic; max-width: 40ch; margin-inline: auto;">
      The vocabulary of reason, defined clearly.
    </p>
    <p style="font-family: var(--font-ui); font-size: var(--text-sm); margin-top: var(--space-4); text-align: center;">
      Know a term we should define? <a href="/glossary/submit/" style="color: var(--color-link); font-weight: 600;">Suggest it</a>
    </p>
  </header>

  {# Search #}
  <div style="max-width:480px;margin:0 auto var(--space-6);">
    <input type="search" id="glossary-search" placeholder="Search terms..." aria-label="Search glossary"
      style="width:100%;font-family:var(--font-ui);font-size:var(--text-sm);padding:var(--space-3) var(--space-4);border:1px solid var(--color-rule);background:var(--color-bg);color:var(--color-ink);border-radius:var(--radius-sm);">
  </div>

  <div class="glossary-layout">

    {# Letter nav — sticky #}
    <nav class="glossary-az" aria-label="Jump to letter">
      {% set letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ" %}
      {% for letter in letters %}
        <a href="#letter-{{ letter }}" class="glossary-az__letter">{{ letter }}</a>
      {% endfor %}
    </nav>

    {# Terms list #}
    <div class="glossary-list" id="glossary-list">
      {% set sorted = collections.glossary | sort(false, false, 'data.title') %}
      {% set currentLetter = '' %}
      {% for entry in sorted %}
        {% set firstLetter = entry.data.title | upper | truncate(1, true, '') %}
        {% if firstLetter != currentLetter %}
          {% set currentLetter = firstLetter %}
          <h2 class="glossary-letter-heading" id="letter-{{ currentLetter }}">{{ currentLetter }}</h2>
        {% endif %}
        <div class="glossary-entry" data-term="{{ entry.data.title | lower }}">
          <dt class="glossary-entry__term">
            <a href="{{ entry.url }}">{{ entry.data.title }}</a>
          </dt>
          <dd class="glossary-entry__def">{{ entry.data.description }}</dd>
        </div>
      {% endfor %}
      <p id="glossary-no-results" hidden style="font-family:var(--font-ui);font-size:var(--text-sm);color:var(--color-ink-faint);font-style:italic;padding:var(--space-6) 0;text-align:center;">No terms match your search.</p>
    </div>

  </div>
</div>

<style>
.glossary-layout {
  display: grid;
  grid-template-columns: 1fr;
  max-width: var(--max-width-prose);
  margin-inline: auto;
  position: relative;
}

/* Letter nav — top sticky bar on desktop */
.glossary-az {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 2px;
  position: sticky;
  top: var(--space-16, 4rem);
  z-index: 10;
  background: var(--color-bg);
  padding: var(--space-2) 0;
  border-bottom: 1px solid var(--color-rule);
  margin-bottom: var(--space-6);
}

.glossary-az__letter {
  font-family: var(--font-ui);
  font-size: var(--text-xs);
  font-weight: 700;
  color: var(--color-ink-faint);
  text-decoration: none;
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 4px;
  transition: background 0.15s, color 0.15s;
}

.glossary-az__letter:hover {
  background: var(--color-ink);
  color: var(--color-bg);
}

/* Letter headings */
.glossary-letter-heading {
  font-family: var(--font-masthead);
  font-size: var(--text-xl);
  font-weight: 700;
  color: var(--color-accent);
  margin: var(--space-8) 0 var(--space-4);
  padding-bottom: var(--space-2);
  border-bottom: 2px solid var(--color-rule);
  scroll-margin-top: 6rem;
}

.glossary-letter-heading:first-of-type {
  margin-top: 0;
}

/* Entries */
.glossary-entry {
  padding: var(--space-4) 0;
  border-bottom: 1px solid var(--color-rule);
}

.glossary-entry__term {
  font-family: var(--font-headline);
  font-size: var(--text-md);
  font-weight: 700;
  margin: 0 0 var(--space-2);
}

.glossary-entry__term a {
  color: var(--color-ink);
  text-decoration: none;
}

.glossary-entry__term a:hover {
  color: var(--color-accent);
}

.glossary-entry__def {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  color: var(--color-ink-muted);
  line-height: 1.6;
  margin: 0;
}

/* Mobile: letter nav as compact horizontal scroll */
@media (max-width: 640px) {
  .glossary-az {
    overflow-x: auto;
    flex-wrap: nowrap;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: var(--space-1) 0;
  }
  .glossary-az::-webkit-scrollbar { display: none; }
  .glossary-az__letter {
    width: 24px;
    height: 24px;
    font-size: 10px;
    flex-shrink: 0;
  }
}
</style>

<script>
(function () {
  var input = document.getElementById('glossary-search');
  var entries = document.querySelectorAll('.glossary-entry');
  var headings = document.querySelectorAll('.glossary-letter-heading');
  var noResults = document.getElementById('glossary-no-results');
  if (!input) return;

  input.addEventListener('input', function () {
    var q = this.value.toLowerCase().trim();
    var visible = 0;

    entries.forEach(function (el) {
      var match = !q || el.dataset.term.indexOf(q) !== -1 ||
        el.querySelector('.glossary-entry__def').textContent.toLowerCase().indexOf(q) !== -1;
      el.style.display = match ? '' : 'none';
      if (match) visible++;
    });

    // Show/hide letter headings based on whether they have visible entries
    headings.forEach(function (h) {
      var next = h.nextElementSibling;
      var hasVisible = false;
      while (next && !next.classList.contains('glossary-letter-heading')) {
        if (next.classList.contains('glossary-entry') && next.style.display !== 'none') hasVisible = true;
        next = next.nextElementSibling;
      }
      h.style.display = hasVisible ? '' : 'none';
    });

    noResults.hidden = visible > 0;
  });
})();
</script>
